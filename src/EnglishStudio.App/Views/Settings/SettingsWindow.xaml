<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.Settings.SettingsWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
                        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        mc:Ignorable="d"
                        Title="{loc:Tr Settings_WindowTitle}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="640" Height="720"
                        WindowStartupLocation="CenterOwner"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">
                <TextBlock Text="{loc:Tr Settings_Header}" Style="{StaticResource H1}" Margin="0,0,0,16" />

                <!-- Colour theme -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_ThemeTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_ThemeHint}" />
                        <ComboBox Style="{StaticResource FlatComboBox}"
                                  ItemsSource="{Binding Themes}"
                                  SelectedValuePath="Theme"
                                  SelectedValue="{Binding Theme}"
                                  HorizontalAlignment="Left" Width="240">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- AI (Claude CLI) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_AiTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_AiHint}" />

                        <TextBlock Text="{loc:Tr Settings_ClaudePathLabel}" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,8"
                                 Text="{Binding ClaudeCliPath, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding ClaudeCliStatus}"
                                   Style="{StaticResource Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <Button Content="{loc:Tr Settings_RecheckButton}"
                                Style="{StaticResource FlatButton}"
                                HorizontalAlignment="Left"
                                Command="{Binding RefreshClaudeStatusCommand}" />
                    </StackPanel>
                </Border>

                <!-- Microphone -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_MicTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_MicHint}" />

                        <ComboBox Style="{StaticResource FlatComboBox}"
                                  ItemsSource="{Binding Microphones}"
                                  SelectedItem="{Binding SelectedMicrophone}"
                                  Margin="0,0,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="{loc:Tr Settings_MicLevel}" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <ProgressBar Minimum="0" Maximum="1"
                                     Value="{Binding MicLevel, Mode=OneWay}"
                                     Height="14"
                                     Foreground="{DynamicResource AccentHotBrush}"
                                     Background="{DynamicResource OverlayDark27Brush}"
                                     BorderThickness="0"
                                     Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding ToggleMicTestCommand}" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                        <Setter Property="Content" Value="{loc:Tr Settings_MicStartTest}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMicTesting}" Value="True">
                                                <Setter Property="Content" Value="{loc:Tr Settings_MicStopTest}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{loc:Tr Settings_MicPlayRecording}"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding PlayTestRecordingCommand}"
                                    IsEnabled="{Binding HasTestRecording}"
                                    Margin="0,0,8,0" />
                            <Button Content="⟳"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding RefreshDevicesCommand}"
                                    ToolTip="{loc:Tr Settings_MicRefreshDevices}" />
                        </StackPanel>

                        <TextBlock Text="{Binding MicStatus}" Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Speaking / Whisper -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_WhisperTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_WhisperHint}" />
                        <ComboBox Style="{StaticResource FlatComboBox}"
                                  ItemsSource="{Binding WhisperOptions}"
                                  SelectedValuePath="Size"
                                  SelectedValue="{Binding WhisperModel}"
                                  Margin="0,0,0,4">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Listening voices -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_VoicesTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_VoicesHint}" />

                        <TextBlock Text="UK female" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,10"
                                 Text="{Binding ListeningVoiceUkFemale, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="UK male" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,10"
                                 Text="{Binding ListeningVoiceUkMale, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="US female" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,10"
                                 Text="{Binding ListeningVoiceUsFemale, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="US male" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,4"
                                 Text="{Binding ListeningVoiceUsMale, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!-- SRS section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_SrsTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />

                        <TextBlock Text="{loc:Tr Settings_SrsNewPerDay}" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,10"
                                 Text="{Binding DailyNewLimit, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{loc:Tr Settings_SrsReviewsPerDay}" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,10"
                                 Text="{Binding DailyReviewLimit, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{loc:Tr Settings_SrsTargetRetention}" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,4"
                                 Text="{Binding TargetRetention, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                    </StackPanel>
                </Border>

                <!-- Pexels -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_PexelsTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_PexelsHint}" />
                        <TextBox Style="{StaticResource FlatTextBox}" Margin="0,0,0,8"
                                 Text="{Binding PexelsApiKey, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="{loc:Tr Settings_PexelsClear}" Style="{StaticResource FlatButton}"
                                HorizontalAlignment="Left"
                                Command="{Binding ClearPexelsCommand}" />
                    </StackPanel>
                </Border>

                <!-- Content pack -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_ContentTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_ContentHint}" />
                        <Button Content="{loc:Tr Settings_ContentImportButton}"
                                Style="{StaticResource FlatButton}"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenContentImportCommand}" />
                    </StackPanel>
                </Border>

                <!-- Database backup -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Settings_BackupTitle}" Style="{StaticResource H2}" Margin="0,0,0,8" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Text="{loc:Tr Settings_BackupHint}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Tr Settings_BackupCreateButton}"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding CreateBackupCommand}" />
                            <Button Content="{loc:Tr Settings_BackupOpenFolderButton}"
                                    Style="{StaticResource FlatButton}"
                                    Margin="8,0,0,0"
                                    Command="{Binding OpenBackupFolderCommand}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Text="{Binding BackupStatus}" />
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Caption}" Foreground="{DynamicResource SuccessBrush}"
                           Text="{Binding SaveStatus}" Margin="0,0,0,12" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{DynamicResource OverlayDark27Brush}"
                BorderBrush="{DynamicResource OverlayLight13Brush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Settings_Save}" Style="{StaticResource AccentButton}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</appshell:ChromedWindow>
