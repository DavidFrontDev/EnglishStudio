<UserControl x:Class="EnglishStudio.App.Views.Trainer.TrainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TrainerViewModel}"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="Transparent"
             Foreground="{DynamicResource PrimaryTextBrush}">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisInverted" Invert="True" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: counters + end session -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource Caption}">
                <Run Text="Сегодня: " />
                <Run Text="{Binding SessionDone}" FontWeight="SemiBold" />
                <Run Text=" из " />
                <Run Text="{Binding SessionTotal}" FontWeight="SemiBold" />
            </TextBlock>
            <Button Grid.Column="1"
                    Content="Начать сессию"
                    Style="{StaticResource AccentButton}"
                    Margin="0,0,8,0"
                    Command="{Binding StartSessionCommand}"
                    Visibility="{Binding IsSessionActive, Converter={StaticResource InverseBoolToVis}}" />
            <Button Grid.Column="2"
                    Content="Завершить"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding EndSessionCommand}"
                    Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <!-- Main card area -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding CurrentCard, Converter={StaticResource NullToVisInverted}}">
                <TextBlock Text="🎯" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,12" />
                <TextBlock Text="Тренажёр готов"
                           Style="{StaticResource H2}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding SessionStatus}"
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Margin="0,0,0,16" />
                <Button Content="Начать сессию"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AccentButton}"
                        Padding="24,10"
                        Command="{Binding StartSessionCommand}" />

                <!-- Per-text practice pools (built from the reader's "🎯 В тренировку") -->
                <StackPanel Margin="0,28,0,0" MaxWidth="520"
                            Visibility="{Binding HasPools, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="🎯 Пулы текстов" Style="{StaticResource H3}" VerticalAlignment="Center" />
                        <Button Content="↻"
                                HorizontalAlignment="Right"
                                Padding="8,2"
                                FontSize="12"
                                Style="{StaticResource FlatButton}"
                                ToolTip="Обновить список"
                                Command="{Binding LoadPoolsCommand}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Pools}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource StrongTextBrush}" />
                                        <Button Grid.Column="1"
                                                Content="▶  Повторить"
                                                Padding="12,5"
                                                FontSize="12"
                                                Style="{StaticResource FlatButton}"
                                                Command="{Binding DataContext.StartPoolSessionCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding TextId}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Card -->
            <Border Style="{StaticResource Card}"
                    Padding="24"
                    Visibility="{Binding CurrentCard, Converter={StaticResource NullToVis}}">
                <Grid DataContext="{Binding CurrentCard}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Front: headword -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding Headword}"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PartOfSpeechNameRu}"
                                   Style="{StaticResource MutedText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- IPA + Audio buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0">
                        <TextBlock Text="{Binding IpaUk}"
                                   Style="{StaticResource MonoText}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Visibility="{Binding IpaUk, Converter={StaticResource NullToVis}}" />
                        <Button Content="🔊 UK"
                                Style="{StaticResource AudioButton}"
                                Margin="10,0,0,0"
                                Visibility="{Binding HasAudioUk, Converter={StaticResource BoolToVis}}"
                                Command="{Binding DataContext.PlayUkCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <Button Content="🔊 US"
                                Style="{StaticResource AudioButton}"
                                Margin="8,0,0,0"
                                Visibility="{Binding HasAudioUs, Converter={StaticResource BoolToVis}}"
                                Command="{Binding DataContext.PlayUsCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>

                    <!-- Reveal button or back content -->
                    <Grid Grid.Row="2" Margin="0,24,0,0">
                        <Button Content="Показать перевод"
                                Style="{StaticResource AccentButton}"
                                Padding="32,12"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                Command="{Binding DataContext.RevealAnswerCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Visibility="{Binding DataContext.IsAnswerRevealed,
                                             Converter={StaticResource InverseBoolToVis},
                                             RelativeSource={RelativeSource AncestorType=UserControl}}" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="320"
                                      Visibility="{Binding DataContext.IsAnswerRevealed,
                                                   Converter={StaticResource BoolToVis},
                                                   RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <StackPanel>
                                <!-- Translations chips -->
                                <ItemsControl ItemsSource="{Binding TranslationsRu}" Margin="0,0,0,8"
                                              HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,6,6"
                                                    Padding="10,4"
                                                    Background="{DynamicResource OverlayLight13Brush}"
                                                    BorderBrush="{DynamicResource OverlayLight33Brush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <TextBlock Text="{Binding}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource StrongTextBrush}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding DefinitionRu}"
                                           Style="{StaticResource BodyText}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding DefinitionRu, Converter={StaticResource NullToVis}}" />

                                <TextBlock Text="{Binding DefinitionEn}"
                                           Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding DefinitionEn, Converter={StaticResource NullToVis}}" />

                                <ItemsControl ItemsSource="{Binding Examples}" Margin="0,16,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardCompact}" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TextEn}" Style="{StaticResource BodyText}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding TextRu}"
                                                               Style="{StaticResource MutedText}"
                                                               FontStyle="Italic"
                                                               Margin="0,3,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding TextRu, Converter={StaticResource NullToVis}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Rating buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0"
              Visibility="{Binding IsAnswerRevealed, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Снова"
                    Style="{StaticResource FlatButton}"
                    Padding="0,12"
                    Margin="0,0,6,0"
                    FontSize="14"
                    Command="{Binding RateAgainCommand}" />
            <Button Grid.Column="1"
                    Content="Сложно"
                    Style="{StaticResource FlatButton}"
                    Padding="0,12"
                    Margin="6,0,6,0"
                    FontSize="14"
                    Command="{Binding RateHardCommand}" />
            <Button Grid.Column="2"
                    Content="Хорошо"
                    Style="{StaticResource AccentButton}"
                    Padding="0,12"
                    Margin="6,0,6,0"
                    FontSize="14"
                    Command="{Binding RateGoodCommand}" />
            <Button Grid.Column="3"
                    Content="Легко"
                    Style="{StaticResource FlatButton}"
                    Padding="0,12"
                    Margin="6,0,0,0"
                    FontSize="14"
                    Command="{Binding RateEasyCommand}" />
        </Grid>
    </Grid>
</UserControl>
