<UserControl x:Class="EnglishStudio.App.Views.ReadingStudy.ReadingSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
             xmlns:local="clr-namespace:EnglishStudio.App.Views.ReadingStudy"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ReadingSummaryViewModel}"
             d:DesignWidth="520" d:DesignHeight="640">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

        <!-- One stat tile (label on top, big value below). -->
        <Style x:Key="StatTile" TargetType="Border" BasedOn="{StaticResource CardCompact}">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource Card}" MaxWidth="540" Padding="22">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{loc:Tr ReadStudy_SummaryTitle}" Style="{StaticResource H2}" />
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource MutedText}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0" />
            </StackPanel>

            <!-- Stat tiles -->
            <WrapPanel Grid.Row="1" Orientation="Horizontal">
                <Border Style="{StaticResource StatTile}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr ReadStudy_Speed}" Style="{StaticResource Caption}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Wpm, StringFormat={}{0:0}}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource StrongTextBrush}" />
                            <TextBlock Text="{loc:Tr ReadStudy_WpmUnit}" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="3,0,0,4" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Caption}"
                                   Margin="0,2,0,0"
                                   Visibility="{Binding HasAverage, Converter={StaticResource BoolToVis}}">
                            <Run Text="{loc:Tr ReadStudy_Average}" /><Run Text="{Binding AverageWpm, Mode=OneWay, StringFormat={}{0:0}}" /><Run Text="{loc:Tr ReadStudy_WpmUnit}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatTile}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr ReadStudy_Time}" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding DurationText}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatTile}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr ReadStudy_WordsRead}" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding WordsRead}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatTile}"
                        Visibility="{Binding AccuracyAvailable, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr ReadStudy_Accuracy}" Style="{StaticResource Caption}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding AccuracyPct, StringFormat={}{0:0}}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="%" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="2,0,0,4" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                            <Run Text="{loc:Tr ReadStudy_Missed}" /><Run Text="{Binding WordsSkipped, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Body: difficult words + history -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <StackPanel>
                    <!-- Analysis-unavailable note -->
                    <TextBlock Text="{loc:Tr ReadStudy_PronUnavailable}"
                               Style="{StaticResource MutedText}"
                               Margin="0,0,0,10"
                               Visibility="{Binding AccuracyAvailable, Converter={StaticResource InvBoolToVis}}" />

                    <!-- Difficult words (tap ɪₚₐ to see the phoneme breakdown) -->
                    <StackPanel Visibility="{Binding HasDifficultWords, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Tr ReadStudy_DifficultWords}" Style="{StaticResource H3}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding DifficultWords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource OverlayLight13Brush}"
                                            BorderBrush="{DynamicResource OverlayLight33Brush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,6"
                                            Margin="0,0,0,6">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Word}"
                                                           Foreground="{DynamicResource StrongTextBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           VerticalAlignment="Center" />
                                                <Button Content="{loc:Tr ReadStudy_Phonetics}"
                                                        Margin="10,0,0,0"
                                                        Padding="8,2"
                                                        FontSize="11"
                                                        Style="{StaticResource FlatButton}"
                                                        ToolTip="{loc:Tr ReadStudy_ShowPhonemeBreakdown}"
                                                        Command="{Binding ToggleGuideCommand}" />
                                                <Button Content="{loc:Tr ReadStudy_AddToStudy}"
                                                        Margin="6,0,0,0"
                                                        Padding="8,2"
                                                        FontSize="11"
                                                        Style="{StaticResource FlatButton}"
                                                        ToolTip="{loc:Tr ReadStudy_AddToStudyTip}"
                                                        Command="{Binding AddToTrainingCommand}"
                                                        Visibility="{Binding CanAdd, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock Text="{loc:Tr ReadStudy_InStudy}"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding Added, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>

                                            <!-- F3 phoneme breakdown -->
                                            <local:PhonemeGuideView DataContext="{Binding Guide}"
                                                                    Margin="0,6,0,0"
                                                                    Visibility="{Binding DataContext.IsGuideVisible, RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- History / WPM trend -->
                    <StackPanel Visibility="{Binding HasHistory, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="{loc:Tr ReadStudy_ReadingHistory}" Style="{StaticResource H3}" VerticalAlignment="Center" />
                            <Button Content="{loc:Tr ReadStudy_Clear}"
                                    HorizontalAlignment="Right"
                                    Padding="8,3"
                                    FontSize="11"
                                    Style="{StaticResource FlatButton}"
                                    ToolTip="{loc:Tr ReadStudy_ClearHistoryTip}"
                                    Command="{Binding ClearHistoryCommand}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding WhenText}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding WpmText}"
                                                   Foreground="{DynamicResource StrongTextBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding AccuracyPct, StringFormat={}{0:0}%}"
                                                   Style="{StaticResource Caption}" VerticalAlignment="Center" MinWidth="34" TextAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Button Content="{loc:Tr ReadStudy_QuestionsButton}"
                        HorizontalAlignment="Left"
                        Padding="14,8"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding QuestionsCommand}" />
                <Button Content="{loc:Tr ReadStudy_CloseSummary}"
                        HorizontalAlignment="Right"
                        Padding="16,8"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding CloseCommand}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
