<UserControl x:Class="EnglishStudio.App.Views.ReadingStudy.NotesPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:NotesPanelViewModel}"
             d:DesignWidth="420" d:DesignHeight="600">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:StringToBrushConverter x:Key="StrToBrush" />
    </UserControl.Resources>

    <Border Style="{StaticResource Card}" Background="{DynamicResource WindowBaseBrush}" MaxWidth="440" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{loc:Tr ReadStudy_NotesTitle}" Style="{StaticResource H2}" VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Content="✕" Padding="8,3" FontSize="12"
                        Style="{StaticResource FlatButton}"
                        ToolTip="{loc:Tr ReadStudy_Close}"
                        Command="{Binding CloseCommand}" />
            </Grid>

            <!-- Add-note editor -->
            <Border Grid.Row="1" Style="{StaticResource CardCompact}" Margin="0,0,0,10"
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr ReadStudy_NewNote}" Style="{StaticResource Caption}" />
                    <TextBlock Text="{Binding PendingQuote}"
                               FontStyle="Italic"
                               Foreground="{DynamicResource StrongTextBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="60"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,4,0,6" />
                    <TextBox Style="{StaticResource FlatTextBox}"
                             Text="{Binding NoteDraft, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="56"
                             VerticalScrollBarVisibility="Auto" />

                    <!-- Colour swatches -->
                    <ItemsControl ItemsSource="{Binding Colors}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="24" Height="24" Margin="0,0,6,0" Cursor="Hand"
                                        Command="{Binding DataContext.PickColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{Binding Converter={StaticResource StrToBrush}}"
                                                    CornerRadius="5" BorderThickness="2"
                                                    BorderBrush="{DynamicResource OverlayLight33Brush}" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="{loc:Tr ReadStudy_Cancel}" Padding="12,5" FontSize="12" Style="{StaticResource FlatButton}" Command="{Binding CancelAddCommand}" />
                        <Button Content="{loc:Tr ReadStudy_Save}" Padding="12,5" FontSize="12" Margin="8,0,0,0" Style="{StaticResource AccentButton}" Command="{Binding SaveNoteCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Notes list -->
            <Grid Grid.Row="2">
                <TextBlock Text="{loc:Tr ReadStudy_NoNotes}"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Visibility="{Binding HasNotes, Converter={StaticResource InvBoolToVis}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Notes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="6" CornerRadius="3" Margin="0,2,10,2"
                                                Background="{Binding Color, Converter={StaticResource StrToBrush}}" />

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Quote}"
                                                       FontStyle="Italic"
                                                       Foreground="{DynamicResource CaptionTextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding NoteText}"
                                                       Foreground="{DynamicResource StrongTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"
                                                       Visibility="{Binding HasText, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Button Content="↪" Padding="7,2" FontSize="12" Margin="0,0,4,0"
                                                    Style="{StaticResource FlatButton}"
                                                    ToolTip="{loc:Tr ReadStudy_GoToPlace}"
                                                    Command="{Binding DataContext.GoToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="🗑" Padding="7,2" FontSize="12"
                                                    Style="{StaticResource FlatButton}"
                                                    ToolTip="{loc:Tr ReadStudy_DeleteNote}"
                                                    Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Button Grid.Row="3"
                    Content="{loc:Tr ReadStudy_Close}"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0"
                    Padding="16,8"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding CloseCommand}" />
        </Grid>
    </Border>
</UserControl>
