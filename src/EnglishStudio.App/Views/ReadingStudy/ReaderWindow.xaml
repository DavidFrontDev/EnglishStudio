<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.ReadingStudy.ReaderWindow"
                        x:Name="ReaderWin"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
                        xmlns:local="clr-namespace:EnglishStudio.App.Views.ReadingStudy"
                        xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:ReaderViewModel}"
                        Title="{Binding Title}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="820"
                        Height="700"
                        MinWidth="420"
                        MinHeight="300"
                        SizeToContent="Height"
                        ResizeMode="CanResizeWithGrip"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None"
                        WindowStartupLocation="CenterScreen"
                        Loaded="OnLoaded"
                        ContentRendered="OnContentRendered">

    <appshell:ChromedWindow.Resources>
        <conv:CefrToBrushConverter x:Key="CefrToBrush" />
        <conv:CefrToStringConverter x:Key="CefrToString" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource OverlayLight33Brush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Border x:Name="Hi"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Margin="1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hi" Property="BorderBrush" Value="{DynamicResource AccentHotBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </appshell:ChromedWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ════ Palette header band ════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource OverlayDark20Brush}"
                BorderBrush="{DynamicResource OverlayLight13Brush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <WrapPanel Orientation="Horizontal" DataContext="{Binding Appearance}">
                <!-- Background swatches -->
                <StackPanel Orientation="Horizontal" Margin="0,4,18,4" VerticalAlignment="Center">
                    <TextBlock Text="Фон" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ItemsControl ItemsSource="{Binding BackgroundSwatches}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SwatchButton}"
                                        Background="{Binding}"
                                        Command="{Binding DataContext.SetBackgroundCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Text colour swatches -->
                <StackPanel Orientation="Horizontal" Margin="0,4,18,4" VerticalAlignment="Center">
                    <TextBlock Text="Текст" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ItemsControl ItemsSource="{Binding TextSwatches}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SwatchButton}"
                                        Background="{Binding}"
                                        Command="{Binding DataContext.SetTextColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Font size -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,4" VerticalAlignment="Center">
                    <TextBlock Text="Размер" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="А−" MinWidth="38" Padding="8,3" Style="{StaticResource FlatButton}" Command="{Binding DecreaseFontCommand}" />
                    <TextBlock Text="{Binding FontSize, StringFormat={}{0:0}}"
                               Foreground="{DynamicResource StrongTextBrush}"
                               FontWeight="SemiBold"
                               MinWidth="30"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="6,0" />
                    <Button Content="А+" MinWidth="38" Padding="8,3" FontSize="15" Style="{StaticResource FlatButton}" Command="{Binding IncreaseFontCommand}" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ════ Read-along toolbar ════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource OverlayDark20Brush}"
                BorderBrush="{DynamicResource OverlayLight13Brush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Start / Stop (one shows at a time) + pre-teach / questions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid VerticalAlignment="Center">
                        <Button Content="▶  Читать вслух"
                                Padding="14,7"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding StartReadingCommand}"
                                Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />
                        <Button Content="⏹  Стоп"
                                Padding="14,7"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding StopReadingCommand}"
                                Visibility="{Binding IsReading, Converter={StaticResource BoolToVis}}" />
                    </Grid>

                    <!-- F1/F2 entry points (hidden during active reading) -->
                    <Button Content="🎓  Подготовка"
                            Padding="12,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Разобрать незнакомые слова перед чтением"
                            Command="{Binding ShowPreTeachCommand}"
                            Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />
                    <Button Content="❓  Вопросы"
                            Padding="12,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Вопросы на понимание текста"
                            Command="{Binding ShowComprehensionCommand}"
                            Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />
                    <Button Content="🗣  Тренировка"
                            Padding="12,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Тренировка произношения: слушать и повторять по предложениям"
                            Command="{Binding ShowShadowingCommand}"
                            Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />

                    <!-- F5: notes / bookmark -->
                    <Button Content="✎"
                            Padding="11,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Заметки к тексту"
                            Command="{Binding ShowNotesCommand}"
                            Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />
                    <Button Content="🔖"
                            Padding="11,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Заложить текущее место"
                            Click="BookmarkButton_Click"
                            Visibility="{Binding IsReading, Converter={StaticResource InvBoolToVis}}" />
                    <Button Content="↩"
                            Padding="11,7"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            ToolTip="Продолжить с закладки"
                            Command="{Binding ContinueFromBookmarkCommand}"
                            Visibility="{Binding HasBookmark, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!-- Progress bar / model-loading / analysing status -->
                <Grid Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource FlatProgressBar}"
                                 Height="10"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="{Binding ProgressFraction, Mode=OneWay}"
                                 Visibility="{Binding IsReading, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding ModelStatus}"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsModelLoading, Converter={StaticResource BoolToVis}}" />
                    <!-- Post-read analysis: small spinner shown until the summary appears -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}">
                        <Ellipse Width="15" Height="15"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 StrokeThickness="2"
                                 Stroke="{DynamicResource AccentHotBrush}"
                                 StrokeDashArray="4 3"
                                 StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="🎧 Анализирую запись…"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- F8: page navigation (multi-page texts, when not reading aloud) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding ShowPager, Converter={StaticResource BoolToVis}}">
                        <Button Content="◀"
                                Padding="11,5"
                                Style="{StaticResource FlatButton}"
                                ToolTip="Предыдущая страница"
                                Command="{Binding PrevPageCommand}"
                                IsEnabled="{Binding CanPrevPage}" />
                        <TextBlock Text="{Binding PageLabel}"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   MinWidth="120"
                                   TextAlignment="Center"
                                   Margin="10,0" />
                        <Button Content="▶"
                                Padding="11,5"
                                Style="{StaticResource FlatButton}"
                                ToolTip="Следующая страница"
                                Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanNextPage}" />
                    </StackPanel>
                </Grid>

                <!-- WPM + timer (while reading) -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsReading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Foreground="{DynamicResource StrongTextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <Run Text="{Binding CurrentWpm, Mode=OneWay, StringFormat={}{0:0}}" />
                        <Run Text=" сл/мин" FontWeight="Normal" Foreground="{DynamicResource CaptionTextBrush}" />
                    </TextBlock>
                    <TextBlock Text="{Binding ElapsedText}"
                               Foreground="{DynamicResource StrongTextBrush}"
                               FontWeight="SemiBold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════ Text body ════ -->
        <Border Grid.Row="2"
                Background="{Binding Appearance.BackgroundBrush}"
                CornerRadius="0,0,9,9"
                ClipToBounds="True">
            <RichTextBox x:Name="Reader"
                         IsReadOnly="True"
                         IsDocumentEnabled="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{Binding Appearance.TextBrush}"
                         FontSize="{Binding Appearance.FontSize}"
                         Padding="24,18"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalScrollBarVisibility="Auto"
                         SpellCheck.IsEnabled="False"
                         AcceptsReturn="False"
                         AcceptsTab="False"
                         Loaded="Reader_Loaded"
                         SelectionChanged="Reader_SelectionChanged" />
        </Border>

        <!-- ════ Translation popup ════ -->
        <Popup x:Name="TransPopup"
               Grid.Row="2"
               IsOpen="{Binding IsPopupOpen}"
               StaysOpen="True"
               AllowsTransparency="True"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=Reader}"
               PopupAnimation="Fade">
            <Border DataContext="{Binding DataContext, ElementName=ReaderWin}"
                    Background="{DynamicResource WindowBaseBrush}"
                    BorderBrush="{DynamicResource OverlayLight33Brush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    MaxWidth="340"
                    Margin="8"
                    Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.5" Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Popup.Query}"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="{DynamicResource StrongTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="200" />
                            <Border Background="{DynamicResource AccentHotBrush}"
                                    CornerRadius="6"
                                    Padding="5,1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="Сгенерировано Claude — не проверено"
                                    Visibility="{Binding Popup.IsAiGenerated, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="🤖 AI" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="✕"
                                Margin="10,0,0,0"
                                Padding="6,2"
                                FontSize="11"
                                VerticalAlignment="Top"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding ClosePopupCommand}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Popup.Ipa}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Popup.PartOfSpeechRu}" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Selection-level actions: note + colour highlight -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="✎  Заметка"
                                Padding="10,4"
                                FontSize="12"
                                Style="{StaticResource FlatButton}"
                                ToolTip="Сохранить выделение как заметку"
                                Click="AddNoteButton_Click" />
                        <Button Margin="6,0,0,0"
                                Padding="10,4"
                                FontSize="12"
                                ToolTip="Подсветить выделенное (фиолетовым). Держится, пока не уберёте."
                                Click="HighlightButton_Click"
                                Visibility="{Binding Popup.CanHighlight, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                    <Setter Property="Content" Value="🖍  Выделить" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Popup.IsSelectionHighlighted}" Value="True">
                                            <Setter Property="Content" Value="🖍  Убрать выделение" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="⏳ ищу перевод…"
                               Style="{StaticResource MutedText}"
                               Margin="0,8,0,0"
                               Visibility="{Binding Popup.IsLoading, Converter={StaticResource BoolToVis}}" />

                    <StackPanel Margin="0,8,0,0" Visibility="{Binding Popup.Found, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Popup.TranslationsLine}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Popup.DefinitionRu}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />

                        <Button Content="📚  В изучение"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Padding="10,5"
                                FontSize="12"
                                Style="{StaticResource AccentButton}"
                                Visibility="{Binding Popup.CanAddToTraining, Converter={StaticResource BoolToVis}}"
                                Command="{Binding Popup.AddToTrainingCommand}" />
                        <TextBlock Text="✓ в изучении"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0"
                                   Visibility="{Binding Popup.AddedToTraining, Converter={StaticResource BoolToVis}}" />

                        <!-- Add to THIS text's practice pool (text-scoped FSRS trainer) -->
                        <Button Content="🎯  В тренировку по тексту"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="10,5"
                                FontSize="12"
                                Style="{StaticResource FlatButton}"
                                ToolTip="Добавить слово в пул тренировки этого текста"
                                Visibility="{Binding Popup.CanAddToPool, Converter={StaticResource BoolToVis}}"
                                Command="{Binding Popup.AddToPoolCommand}" />
                        <TextBlock Text="✓ в пуле текста"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding Popup.AddedToPool, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <TextBlock Text="{Binding Popup.Message}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Popup>

        <!-- ════ Post-read summary overlay ════ -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#C0000000"
                Visibility="{Binding IsSummaryVisible, Converter={StaticResource BoolToVis}}">
            <local:ReadingSummaryView DataContext="{Binding Summary}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      MaxWidth="560"
                                      MaxHeight="640"
                                      Margin="24" />
        </Border>

        <!-- ════ Pre-teach overlay (F1) ════ -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Panel.ZIndex="11"
                Background="#C0000000"
                Visibility="{Binding IsPreTeachVisible, Converter={StaticResource BoolToVis}}">
            <local:PreTeachView DataContext="{Binding PreTeach}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="560"
                                MaxHeight="660"
                                Margin="24" />
        </Border>

        <!-- ════ Comprehension overlay (F2) ════ -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Panel.ZIndex="12"
                Background="#C0000000"
                Visibility="{Binding IsComprehensionVisible, Converter={StaticResource BoolToVis}}">
            <local:ComprehensionView DataContext="{Binding Comprehension}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     MaxWidth="600"
                                     MaxHeight="680"
                                     Margin="24" />
        </Border>

        <!-- ════ Shadowing overlay (F4) ════ -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Panel.ZIndex="13"
                Background="#C0000000"
                Visibility="{Binding IsShadowingVisible, Converter={StaticResource BoolToVis}}">
            <local:ShadowingView DataContext="{Binding Shadowing}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 MaxWidth="600"
                                 MaxHeight="700"
                                 Margin="24" />
        </Border>

        <!-- ════ Notes overlay (F5) ════ -->
        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Panel.ZIndex="14"
                Background="#C0000000"
                Visibility="{Binding IsNotesVisible, Converter={StaticResource BoolToVis}}">
            <local:NotesPanelView DataContext="{Binding NotesPanel}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  MaxWidth="460"
                                  MaxHeight="660"
                                  Margin="24" />
        </Border>
    </Grid>
</appshell:ChromedWindow>
