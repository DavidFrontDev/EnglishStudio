<UserControl x:Class="EnglishStudio.App.Views.ReadingStudy.ReadingLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
             xmlns:local="clr-namespace:EnglishStudio.App.Views.ReadingStudy"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ReadingLibraryViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:CefrToBrushConverter x:Key="CefrToBrush" />
        <conv:CefrToStringConverter x:Key="CefrToString" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Rename/Delete: hidden for built-in (read-only) texts. -->
        <Style x:Key="OwnerActionButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source}" Value="Builtin">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- "Built-in" badge: shown only for built-in texts. -->
        <Style x:Key="BuiltinBadge" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource OverlayLight20Brush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source}" Value="Builtin">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hide (🙈): shown only for built-in texts that aren't already hidden — built-ins can't be
             deleted (they re-seed), so hiding is how the user removes them from the library. -->
        <Style x:Key="HideActionButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Source}" Value="Builtin" />
                        <Condition Binding="{Binding IsHidden}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Restore (↩): shown only for currently-hidden texts (visible when "show hidden" is on). -->
        <Style x:Key="RestoreActionButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{loc:Tr Reader_LibraryTitle}" Style="{StaticResource H1}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{loc:Tr Reader_Progress}"
                        Padding="14,8"
                        Margin="0,0,8,0"
                        Style="{StaticResource FlatButton}"
                        ToolTip="{loc:Tr Reader_ProgressTooltip}"
                        Command="{Binding ShowProgressCommand}" />
                <Button Content="{loc:Tr Reader_AddText}"
                        Padding="14,8"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding AddTextCommand}" />
            </StackPanel>
        </Grid>

        <!-- F7 filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="{loc:Tr Reader_Source}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Width="150" VerticalAlignment="Center"
                      ItemsSource="{Binding SourceOptions}"
                      SelectedValuePath="Token"
                      SelectedValue="{Binding SelectedSource, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{loc:Tr Reader_Level}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="18,0,8,0" />
            <ComboBox Width="120" VerticalAlignment="Center"
                      ItemsSource="{Binding CefrOptions}"
                      SelectedValuePath="Token"
                      SelectedValue="{Binding SelectedCefr, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <CheckBox Content="{loc:Tr Reader_ShowHidden}"
                      VerticalAlignment="Center"
                      Margin="18,0,0,0"
                      IsChecked="{Binding ShowHidden, Mode=TwoWay}" />
        </StackPanel>

        <!-- Status / empty state -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   Style="{StaticResource MutedText}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <!-- Texts -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Texts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}"
                                Width="280"
                                Margin="0,0,12,12"
                                VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           TextWrapping="Wrap"
                                           MaxHeight="44"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,8" />

                                <!-- Meta row -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Background="{Binding EstimatedCefr, Converter={StaticResource CefrToBrush}}"
                                            CornerRadius="6"
                                            Padding="7,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedCefr, Converter={StaticResource CefrToString}}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="11" />
                                    </Border>
                                    <TextBlock Style="{StaticResource Caption}" Text="  ·  " VerticalAlignment="Center" />
                                    <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center">
                                        <Run Text="{Binding WordCount, Mode=OneWay}" />
                                        <Run Text="{loc:Tr Reader_Words}" />
                                    </TextBlock>

                                    <!-- Last reading speed (after a read-along session) -->
                                    <TextBlock Style="{StaticResource Caption}"
                                               Text="  ·  "
                                               VerticalAlignment="Center"
                                               Visibility="{Binding LastWpm, Converter={StaticResource NullToVis}}" />
                                    <TextBlock Style="{StaticResource Caption}"
                                               VerticalAlignment="Center"
                                               ToolTip="{loc:Tr Reader_LastWpmTooltip}"
                                               Visibility="{Binding LastWpm, Converter={StaticResource NullToVis}}">
                                        <Run Text="📈 " />
                                        <Run Text="{Binding LastWpm, Mode=OneWay, StringFormat={}{0:0}}" />
                                        <Run Text="{loc:Tr Reader_WordsPerMin}" />
                                    </TextBlock>

                                    <Border Style="{StaticResource BuiltinBadge}" Margin="6,0,0,0" ToolTip="{loc:Tr Reader_BuiltinTooltip}">
                                        <TextBlock Text="{loc:Tr Reader_BuiltinBadge}" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>

                                <!-- Actions -->
                                <Grid Grid.Row="2">
                                    <Button Content="{loc:Tr Reader_Read}"
                                            HorizontalAlignment="Left"
                                            Padding="12,6"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="🎓"
                                                Padding="10,6"
                                                FontSize="13"
                                                Margin="0,0,6,0"
                                                Style="{StaticResource FlatButton}"
                                                ToolTip="{loc:Tr Reader_PrepareTooltipLib}"
                                                Command="{Binding DataContext.PrepareCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="✏"
                                                Padding="10,6"
                                                FontSize="13"
                                                Margin="0,0,6,0"
                                                Style="{StaticResource OwnerActionButton}"
                                                ToolTip="{loc:Tr Reader_RenameTooltip}"
                                                Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="🗑"
                                                Padding="10,6"
                                                FontSize="13"
                                                Style="{StaticResource OwnerActionButton}"
                                                ToolTip="{loc:Tr Reader_DeleteTooltip}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="🙈"
                                                Padding="10,6"
                                                FontSize="13"
                                                Style="{StaticResource HideActionButton}"
                                                ToolTip="{loc:Tr Reader_HideTooltip}"
                                                Command="{Binding DataContext.HideCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="↩"
                                                Padding="10,6"
                                                FontSize="13"
                                                Style="{StaticResource RestoreActionButton}"
                                                ToolTip="{loc:Tr Reader_RestoreTooltip}"
                                                Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ════ F6 progress overlay ════ -->
        <Border Grid.Row="0"
                Grid.RowSpan="4"
                Panel.ZIndex="20"
                Background="#C0000000"
                Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
            <local:ReadingProgressView DataContext="{Binding Progress}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       MaxWidth="700"
                                       MaxHeight="660"
                                       Margin="24" />
        </Border>
    </Grid>
</UserControl>
