<UserControl x:Class="EnglishStudio.App.Views.ReadingStudy.PreTeachView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:PreTeachViewModel}"
             d:DesignWidth="540" d:DesignHeight="640">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:CefrToBrushConverter x:Key="CefrToBrush" />
        <conv:CefrToStringConverter x:Key="CefrToString" />
    </UserControl.Resources>

    <Border Style="{StaticResource Card}" Background="{DynamicResource WindowBaseBrush}" MaxWidth="560" Padding="22">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{loc:Tr ReadStudy_PreTeachTitle}" Style="{StaticResource H2}" />
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,2,0,0" TextWrapping="Wrap">
                        <Run Text="{loc:Tr ReadStudy_Known}" /><Run Text=" " /><Run Text="{Binding KnownCount, Mode=OneWay}" /><Run Text="{loc:Tr ReadStudy_Of}" /><Run Text="{Binding TotalDistinctWords, Mode=OneWay}" /><Run Text="{loc:Tr ReadStudy_WordsMarkUnknown}" />
                    </TextBlock>
                    <TextBlock Text="{loc:Tr ReadStudy_ClaudeUnavailable}"
                               Style="{StaticResource MutedText}"
                               Foreground="{DynamicResource WarningBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding CanEnrich, Converter={StaticResource InvBoolToVis}}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="✕"
                        VerticalAlignment="Top"
                        Margin="10,0,0,0"
                        Padding="8,3"
                        FontSize="12"
                        Style="{StaticResource FlatButton}"
                        ToolTip="{loc:Tr ReadStudy_Close}"
                        Command="{Binding CloseCommand}" />
            </Grid>

            <!-- Select all / none -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding HasCandidates, Converter={StaticResource BoolToVis}}">
                <Button Content="{loc:Tr ReadStudy_SelectAll}" Padding="10,4" FontSize="12" Style="{StaticResource FlatButton}" Command="{Binding SelectAllCommand}" />
                <Button Content="{loc:Tr ReadStudy_SelectNone}" Padding="10,4" FontSize="12" Margin="8,0,0,0" Style="{StaticResource FlatButton}" Command="{Binding SelectNoneCommand}" />
            </StackPanel>

            <!-- Loading / empty / list -->
            <Grid Grid.Row="2">
                <TextBlock Text="{loc:Tr ReadStudy_AnalyzingText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Top"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Visibility="{Binding HasCandidates, Converter={StaticResource InvBoolToVis}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasCandidates, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Candidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"
                                                  IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding CanSelect}" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Headword}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="{DynamicResource StrongTextBrush}"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{Binding Cefr, Converter={StaticResource CefrToBrush}}"
                                                        CornerRadius="6" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Cefr, Converter={StaticResource CefrToString}}"
                                                               Foreground="White" FontWeight="SemiBold" FontSize="10" />
                                                </Border>
                                                <Border Background="{DynamicResource AccentHotBrush}"
                                                        CornerRadius="6" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{loc:Tr ReadStudy_AiWordTip}"
                                                        Visibility="{Binding IsAiWord, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="🤖 AI" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="{DynamicResource SuccessBrush}"
                                                        CornerRadius="6" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{loc:Tr ReadStudy_AlreadyInStudyTip}"
                                                        Visibility="{Binding AlreadyInTraining, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{loc:Tr ReadStudy_Studying}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TranslationDisplay}"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource Caption}"
                                                   ToolTip="{loc:Tr ReadStudy_OccurrencesTip}">
                                            <Run Text="×" /><Run Text="{Binding Occurrences, Mode=OneWay}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding AddProgress}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,12,0"
                           Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{loc:Tr ReadStudy_StudySelected}"
                            Padding="14,8"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding StudySelectedCommand}"
                            Visibility="{Binding HasCandidates, Converter={StaticResource BoolToVis}}" />
                    <Button Content="{loc:Tr ReadStudy_StartReading}"
                            Padding="14,8"
                            Margin="10,0,0,0"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding CloseCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
