<UserControl x:Class="EnglishStudio.App.Views.ReadingStudy.ShadowingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.ReadingStudy"
             xmlns:local="clr-namespace:EnglishStudio.App.Views.ReadingStudy"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ShadowingViewModel}"
             d:DesignWidth="560" d:DesignHeight="680">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <!-- Opaque card (overlay sits over the text). -->
    <Border Style="{StaticResource Card}" Background="{DynamicResource WindowBaseBrush}" MaxWidth="600" Padding="22">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🗣  Тренировка произношения" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding PositionText}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="✕"
                        VerticalAlignment="Top"
                        Padding="8,3"
                        FontSize="12"
                        Style="{StaticResource FlatButton}"
                        ToolTip="Закрыть"
                        Command="{Binding CloseCommand}" />
            </Grid>

            <!-- Current sentence + controls -->
            <Border Grid.Row="1" Style="{StaticResource CardCompact}"
                    Visibility="{Binding HasSentences, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentText}"
                               FontSize="16"
                               Foreground="{DynamicResource StrongTextBrush}"
                               TextWrapping="Wrap" />

                    <!-- Playback controls -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                        <Button Content="▶  Прослушать"
                                Padding="12,6"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding PlayCurrentCommand}"
                                IsEnabled="{Binding TtsAvailable}"
                                Visibility="{Binding IsSpeaking, Converter={StaticResource InvBoolToVis}}" />
                        <Button Content="⏹  Стоп"
                                Padding="12,6"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding StopSpeakCommand}"
                                Visibility="{Binding IsSpeaking, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="Темп" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="14,0,6,0" />
                        <Slider Width="110"
                                VerticalAlignment="Center"
                                Minimum="0.75" Maximum="1.0"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                Value="{Binding Rate, Mode=TwoWay}" />
                        <TextBlock Text="{Binding Rate, StringFormat={}{0:0.00}×}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="6,0,0,0" />

                        <ComboBox Width="150"
                                  Margin="14,0,0,0"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Voices}"
                                  SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                                  Visibility="{Binding TtsAvailable, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- Record controls -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                        <Button Content="🎤  Повторить"
                                Padding="12,6"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding RecordToggleCommand}"
                                Visibility="{Binding IsRecording, Converter={StaticResource InvBoolToVis}}" />
                        <Button Content="⏹  Закончить и оценить"
                                Padding="12,6"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding RecordToggleCommand}"
                                Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="🎧 оцениваю…"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Visibility="{Binding IsScoring, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}" />
                </StackPanel>
            </Border>

            <!-- Score -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0"
                          Visibility="{Binding HasScore, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding ScoreAccuracy, StringFormat={}{0:0}%}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock VerticalAlignment="Bottom" Margin="8,0,0,3" Style="{StaticResource Caption}">
                            <Run Text="сказано" /><Run Text=" " /><Run Text="{Binding WordsSpoken, Mode=OneWay}" /><Run Text=" из " /><Run Text="{Binding WordsExpected, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding WordResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource OverlayLight13Brush}"
                                        CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- status glyph -->
                                            <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" Width="18"
                                                       Visibility="{Binding IsGood, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="≈" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" Width="18"
                                                       Visibility="{Binding IsMispronounced, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="✗" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold" Width="18"
                                                       Visibility="{Binding IsSkipped, Converter={StaticResource BoolToVis}}" />

                                            <TextBlock Text="{Binding Word}"
                                                       Foreground="{DynamicResource StrongTextBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />

                                            <Button Content="ɪ/ə разбор"
                                                    Margin="10,0,0,0"
                                                    Padding="8,1"
                                                    FontSize="11"
                                                    Style="{StaticResource FlatButton}"
                                                    Command="{Binding ToggleGuideCommand}"
                                                    Visibility="{Binding IsGood, Converter={StaticResource InvBoolToVis}}" />
                                        </StackPanel>

                                        <local:PhonemeGuideView DataContext="{Binding Guide}"
                                                                Margin="20,6,0,0"
                                                                Visibility="{Binding DataContext.IsGuideVisible, RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer: navigation -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="◀  Назад"
                            Padding="14,8"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding PrevCommand}"
                            IsEnabled="{Binding CanGoPrev}" />
                    <Button Content="Вперёд  ▶"
                            Padding="14,8"
                            Margin="8,0,0,0"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding NextCommand}"
                            IsEnabled="{Binding CanGoNext}" />
                </StackPanel>
                <Button Content="Закрыть"
                        HorizontalAlignment="Right"
                        Padding="16,8"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding CloseCommand}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
