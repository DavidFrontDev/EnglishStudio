<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.Content.ContentImportWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Content"
                        xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:ContentImportViewModel}"
                        Title="{loc:Tr Content_ImportTitle}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="540" Height="600"
                        ResizeMode="NoResize"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None"
                        WindowStartupLocation="CenterOwner"
                        ShowInTaskbar="False">

    <appshell:ChromedWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </appshell:ChromedWindow.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">
                <TextBlock Text="{loc:Tr Content_ImportHeader}" Style="{StaticResource H1}" Margin="0,0,0,6" />
                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="{loc:Tr Content_ImportHint}" />

                <!--  Source pickers  -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="{loc:Tr Content_ChooseFolder}"
                            Style="{StaticResource FlatButton}"
                            Margin="0,0,8,0"
                            Command="{Binding ChooseFolderCommand}" />
                    <Button Content="{loc:Tr Content_ChooseZip}"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ChooseZipCommand}" />
                </StackPanel>

                <!--  Selected path  -->
                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,12"
                        Visibility="{Binding SelectedPath, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Content_SelectedPak}" Style="{StaticResource Caption}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedPath}" Style="{StaticResource MonoText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  Detected sections (preview)  -->
                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,12"
                        Visibility="{Binding HasDetectedSections, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Content_Sections}" Style="{StaticResource H3}" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding DetectedSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,1">
                                        <Run Text="•  " Foreground="{DynamicResource AccentHotBrush}" /><Run Text="{Binding Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--  Progress  -->
                <ProgressBar Style="{StaticResource FlatProgressBar}"
                             Minimum="0" Maximum="1"
                             Value="{Binding Progress, Mode=OneWay}"
                             Margin="0,4,0,8"
                             Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!--  Summary (after import)  -->
                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,12"
                        Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Content_ImportSummary}" Style="{StaticResource H3}" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding Summary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Mode=OneWay}" Style="{StaticResource MutedText}" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--  Errors  -->
                <Border Style="{StaticResource CardCompact}" Margin="0,0,0,12"
                        Visibility="{Binding HasErrors, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr Content_Errors}" Style="{StaticResource H3}" Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding Errors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Mode=OneWay}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  Action bar  -->
        <Border Grid.Row="1"
                Background="{DynamicResource OverlayDark27Brush}"
                BorderBrush="{DynamicResource OverlayLight13Brush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Content_ImportButton}"
                        Style="{StaticResource AccentButton}"
                        Margin="0,0,8,0"
                        Command="{Binding ImportCommand}" />
                <Button Content="{loc:Tr Content_Done}"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding DoneCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</appshell:ChromedWindow>
