<UserControl x:Class="EnglishStudio.App.Views.Reading.ReadingTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Reading"
             xmlns:rdg="clr-namespace:EnglishStudio.App.Views.Reading"
             xmlns:lsn="clr-namespace:EnglishStudio.App.Views.Listening"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ReadingTestViewModel}"
             d:DesignHeight="760" d:DesignWidth="1280">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/EnglishStudio.App;component/Views/Listening/CardTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!--  Reading override of AnketaCardTemplate: instead of hugging the widest line and
                  left-aligning (the shared Listening behaviour), the card fills the right zone.
                  MinWidth = ScrollViewer.ViewportWidth makes the border stretch to the zone width
                  when the form is narrow; HorizontalScrollBarVisibility=Auto still lets a single
                  over-long no-wrap line scroll instead of being clipped.  -->
            <DataTemplate x:Key="ReadingAnketaCardTemplate">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ListeningCardHeader}" />
                        <Border Background="{DynamicResource OverlayDark20Brush}"
                                BorderBrush="{DynamicResource OverlayLight17Brush}"
                                BorderThickness="1" CornerRadius="6" Padding="16,14"
                                HorizontalAlignment="Stretch"
                                MinWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource LSubtract}, ConverterParameter=2}">
                            <StackPanel lsn:StructuredNotesRenderer.Card="{Binding}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <lsn:CardLayoutTemplateSelector x:Key="CardSelector"
                                            Anketa="{StaticResource ReadingAnketaCardTemplate}"
                                            SummaryFlow="{StaticResource SummaryFlowCardTemplate}"
                                            Table="{StaticResource TableCardTemplate}"
                                            Comparison="{StaticResource ComparisonCardTemplate}"
                                            Cascade="{StaticResource CascadeCardTemplate}"
                                            CascadeImage="{StaticResource CascadeImageCardTemplate}"
                                            Selector="{StaticResource SelectorCardTemplate}"
                                            AnketaImage="{StaticResource AnketaImageCardTemplate}"
                                            Choice="{StaticResource ChoiceCardTemplate}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Top bar  -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TestTitle}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding CardPositionLabel}" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource OverlayDark27Brush}"
                        BorderBrush="{DynamicResource OverlayLight20Brush}"
                        BorderThickness="1" CornerRadius="6" Padding="14,6" Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding TimerVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱  " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TimerLabel}" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Caption}" Text="{Binding ProgressLabel}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <Button Content="{loc:Tr ReadIelts_Cancel}" Style="{StaticResource FlatButton}" Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Two zones: passage (left) | current card (right)  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <!--  Passage  -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="{Binding PassageTitle}" Style="{StaticResource H2}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PassageNote}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding PassageNote, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock rdg:PassageRenderer.Body="{Binding PassageBody}" TextWrapping="Wrap" LineHeight="26"
                                   FontSize="14.5" Foreground="{DynamicResource PrimaryTextBrush}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!--  Current card  -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <ContentControl Content="{Binding CurrentCard}" ContentTemplateSelector="{StaticResource CardSelector}" />
            </Border>
        </Grid>

        <!--  Card indicator  -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Cards}" Margin="0,10,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="34" Height="30" Margin="3,0"
                            Command="{Binding DataContext.JumpToCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource OverlayLight13Brush}"
                                                    BorderBrush="{DynamicResource OverlayLight20Brush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="{Binding CardNumber}" FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHotBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentHotBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  Bottom nav  -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Tr ReadIelts_Back}" Style="{StaticResource FlatButton}" Command="{Binding PrevCardCommand}" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource MutedText}" Text="{Binding CardPositionLabel}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="{loc:Tr ReadIelts_Forward}" Style="{StaticResource FlatButton}" Margin="0,0,8,0" Command="{Binding NextCardCommand}" />
                <Button Content="{loc:Tr ReadIelts_Finish}" Style="{StaticResource AccentButton}" Command="{Binding FinishCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
