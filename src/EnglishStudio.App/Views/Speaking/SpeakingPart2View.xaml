<UserControl x:Class="EnglishStudio.App.Views.Speaking.SpeakingPart2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Speaking"
             xmlns:ctrl="clr-namespace:EnglishStudio.App.Views.Speaking.Controls"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SpeakingPart2ViewModel}"
             d:DesignHeight="640" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding PartTitle}"
                   Style="{StaticResource H2}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,18" />

        <!-- cue card -->
        <Border Grid.Row="1"
                Background="{DynamicResource OverlayLight20Brush}"
                CornerRadius="10"
                Padding="22,18"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="{Binding CueCardPrompt}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource StrongTextBrush}"
                           Margin="0,0,0,10" />
                <TextBlock Text="You should say:"
                           Style="{StaticResource Caption}" />
                <TextBlock Text="{Binding SubpointsText}"
                           Style="{StaticResource BodyText}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- giant timers (prep phase = blue, record phase = red) -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#26365E"
                    CornerRadius="10" Padding="20,14" Margin="0,0,8,0"
                    Visibility="{Binding IsPreparing, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ПОДГОТОВКА"
                               FontWeight="SemiBold"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="#A4C0FF" />
                    <TextBlock Text="{Binding PrepDisplay}"
                               FontSize="46"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="White" />
                    <Button Content="Пропустить и начать"
                            Style="{StaticResource FlatButton}"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"
                            Command="{Binding SkipPrepCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="#5C2A2A"
                    CornerRadius="10" Padding="20,14" Margin="8,0,0,0"
                    Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ЗАПИСЬ"
                               FontWeight="SemiBold"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="#FFB7B7" />
                    <TextBlock Text="{Binding RecordDisplay}"
                               FontSize="46"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- recorder + transcript -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button Content="🕐 Начать минуту подготовки"
                        Style="{StaticResource AccentButton}"
                        Padding="22,10"
                        Command="{Binding StartPrepCommand}"
                        Visibility="{Binding CanStartPrep, Converter={StaticResource BoolToVis}}" />

                <ctrl:RecordingButton
                    IsRecording="{Binding IsRecording}"
                    IsProcessing="{Binding IsTranscribing}"
                    TranscribeProgress="{Binding TranscribeProgress}"
                    RemainingSeconds="{Binding RecordRemaining}"
                    MaxDurationSeconds="120"
                    RecordRequested="OnRecordRequested"
                    StopRequested="OnStopRequested" />
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource Card}"
                    Visibility="{Binding Transcript, Converter={StaticResource NullToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Транскрипт"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding Transcript}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource MutedText}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <Button Content="Завершить Part 2 →"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding FinishCommand}"
                    IsEnabled="{Binding CanFinish}" />
        </StackPanel>
    </Grid>
</UserControl>
