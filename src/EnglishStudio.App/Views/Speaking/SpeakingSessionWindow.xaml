<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.Speaking.SpeakingSessionWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Speaking"
                        xmlns:views="clr-namespace:EnglishStudio.App.Views.Speaking"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:SpeakingSessionViewModel}"
                        Title="{Binding SessionTitle}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="1180" Height="780"
                        MinWidth="960" MinHeight="620"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None"
                        WindowStartupLocation="CenterOwner">
    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.22,0.18" GradientOrigin="0.22,0.18" RadiusX="1.25" RadiusY="1.6">
                    <GradientStop Offset="0" Color="{DynamicResource AccentHotColor}" />
                    <GradientStop Offset="0.35" Color="{DynamicResource AccentMidColor}" />
                    <GradientStop Offset="0.8" Color="{DynamicResource AccentDeepColor}" />
                    <GradientStop Offset="1" Color="{DynamicResource AccentEdgeColor}" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.85" RadiusY="0.85">
                    <GradientStop Offset="0.55" Color="#00000000" />
                    <GradientStop Offset="1" Color="#66000000" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <views:SpeakingSessionView Margin="18" />
    </Grid>
</appshell:ChromedWindow>
