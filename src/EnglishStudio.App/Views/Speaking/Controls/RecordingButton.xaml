<UserControl x:Class="EnglishStudio.App.Views.Speaking.Controls.RecordingButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="220">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- IDLE -->
        <Button x:Name="IdleButton"
                Content="{loc:Tr Speaking_StartRecording}"
                Padding="22,10"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{DynamicResource StrongTextBrush}"
                Background="{DynamicResource RecordStartBrush}"
                BorderThickness="0"
                Cursor="Hand"
                Click="OnIdleClick"
                Visibility="{Binding ShowIdle, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="22" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- RECORDING -->
        <Button x:Name="RecordingBtn"
                Padding="22,10"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{DynamicResource StrongTextBrush}"
                Background="{DynamicResource RecordStopBrush}"
                BorderThickness="0"
                Cursor="Hand"
                Click="OnStopClick"
                Visibility="{Binding ShowRecording, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="22" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" Fill="White">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2"
                                                     Duration="0:0:0.7"
                                                     AutoReverse="True" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="{loc:Tr Speaking_StopDot}" />
                <TextBlock x:Name="RemainingLabel" Text="00:30" />
            </StackPanel>
        </Button>

        <!-- PROCESSING -->
        <Border Background="{DynamicResource OverlayLight20Brush}"
                CornerRadius="14"
                Padding="20,10"
                Visibility="{Binding ShowProcessing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
            <StackPanel MinWidth="210">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid Width="18" Height="18" Margin="0,0,10,0">
                    <Ellipse Width="18" Height="18"
                             Stroke="{DynamicResource OverlayLight20Brush}"
                             StrokeThickness="2" />
                    <Path Stroke="{DynamicResource AccentHotBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          Data="M 9,1 A 8,8 0 0 1 17,9"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" Angle="0" />
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:0.9" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>
                <TextBlock Text="{Binding ProcessingCaption, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource StrongTextBrush}"
                           VerticalAlignment="Center" />
                </StackPanel>
                <!--  Детерминированный прогресс: доля транскрибированного аудио  -->
                <ProgressBar Height="5"
                             Minimum="0" Maximum="1"
                             Margin="0,8,0,0"
                             Background="{DynamicResource OverlayLight13Brush}"
                             Foreground="{DynamicResource AccentHotBrush}"
                             BorderThickness="0"
                             Value="{Binding TranscribeProgress, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
