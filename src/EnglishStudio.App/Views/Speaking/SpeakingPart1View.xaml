<UserControl x:Class="EnglishStudio.App.Views.Speaking.SpeakingPart1View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Speaking"
             xmlns:ctrl="clr-namespace:EnglishStudio.App.Views.Speaking.Controls"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SpeakingPart1ViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding ProgressLabel}"
                   Style="{StaticResource H2}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,18" />

        <Border Grid.Row="1"
                Background="{DynamicResource OverlayLight20Brush}"
                CornerRadius="10"
                Padding="22,18"
                Margin="0,0,0,18">
            <TextBlock Text="{Binding CurrentQuestion.Text}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource StrongTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12"
                    Visibility="{Binding IsPreparing, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayLight13Brush}"
                    CornerRadius="6" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Tr Speaking_Preparing}"
                               Foreground="{DynamicResource StrongTextBrush}" />
                    <TextBlock Text="{Binding PrepRemaining}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentHotBrush}" />
                    <TextBlock Text="{loc:Tr Speaking_Sec}" Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </Border>
            <Button Content="{loc:Tr Speaking_Skip}"
                    Style="{StaticResource FlatButton}"
                    Margin="10,0,0,0"
                    Command="{Binding SkipPrepCommand}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,4,0,12">
                <ctrl:RecordingButton
                    IsRecording="{Binding IsRecording}"
                    IsProcessing="{Binding IsTranscribing}"
                    TranscribeProgress="{Binding TranscribeProgress}"
                    RemainingSeconds="{Binding RecordRemaining}"
                    MaxDurationSeconds="30"
                    RecordRequested="OnRecordRequested"
                    StopRequested="OnStopRequested" />

                <Button Content="{loc:Tr Speaking_TenSecPrep}"
                        Style="{StaticResource FlatButton}"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"
                        Command="{Binding StartPrepCommand}"
                        Visibility="{Binding CanPrepare, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource Card}"
                    Visibility="{Binding CurrentTranscript, Converter={StaticResource NullToVis}}">
                <StackPanel>
                    <TextBlock Text="{loc:Tr Speaking_Transcript}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource StrongTextBrush}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding CurrentTranscript}"
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource MutedText}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <Button Content="{loc:Tr Speaking_NextQuestion}"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding GoNextCommand}"
                    IsEnabled="{Binding CanGoNext}" />
        </StackPanel>
    </Grid>
</UserControl>
