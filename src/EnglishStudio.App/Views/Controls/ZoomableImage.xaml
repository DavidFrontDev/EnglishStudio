<UserControl x:Class="EnglishStudio.App.Views.Controls.ZoomableImage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             Cursor="Hand"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             MouseLeftButtonUp="OnImageClick"
             ToolTip="Нажмите, чтобы увеличить (200%)">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Image x:Name="Img"
               Source="{Binding Source, ElementName=Root}"
               Stretch="{Binding Stretch, ElementName=Root}"
               StretchDirection="{Binding StretchDirection, ElementName=Root}"
               MaxHeight="{Binding MaxImageHeight, ElementName=Root}"
               MaxWidth="{Binding MaxImageWidth, ElementName=Root}"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <!--  Лупа: появляется при наведении, подсказывает что картинку можно увеличить  -->
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,6,6,0"
                Background="#B0000000"
                CornerRadius="13"
                Padding="6,3"
                IsHitTestVisible="False"
                Visibility="{Binding IsMouseOver, ElementName=Root, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="🔍" FontSize="14" Foreground="White" />
        </Border>
    </Grid>
</UserControl>
