<UserControl x:Class="EnglishStudio.App.Views.Mock.MockHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Mock"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MockHubViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:EnumBoolConverter x:Key="EnumBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="520" />
            <ColumnDefinition Width="1*" MinWidth="280" />
        </Grid.ColumnDefinitions>

        <!--  Left: header + resume + mode + bundles + start  -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{loc:Tr Mock_FullExamTitle}" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="{loc:Tr Mock_FullExamDesc}" />
            </StackPanel>

            <!--  Resume banner — только при незаконченном экзамене  -->
            <Border Grid.Row="1"
                    Background="{DynamicResource OverlayLight20Brush}"
                    CornerRadius="8"
                    Padding="14,10"
                    Margin="0,0,0,10"
                    Visibility="{Binding ResumableMock, Converter={StaticResource NullToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   Text="{loc:Tr Mock_UnfinishedExam}" />
                        <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                            <Run Text="Cambridge " /><Run Text="{Binding ResumableMock.Book, Mode=OneWay}" />
                            <Run Text=" · Test " /><Run Text="{Binding ResumableMock.TestNumber, Mode=OneWay}" />
                            <Run Text="{loc:Tr Mock_ResumeSection}" /><Run Text="{Binding ResumableMock.CurrentSection, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{loc:Tr Mock_Resume}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0"
                            Command="{Binding ResumeCommand}" />
                    <Button Grid.Column="2"
                            Content="{loc:Tr Mock_Discard}"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding DiscardResumableCommand}" />
                </Grid>
            </Border>

            <!--  Mode selector  -->
            <Border Grid.Row="2"
                    Background="{DynamicResource OverlayLight13Brush}"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Tr Mock_Mode}" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <RadioButton Content="{loc:Tr Mock_SelectedTest}"
                                 GroupName="MockMode"
                                 VerticalAlignment="Center"
                                 Margin="0,0,16,0"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBool}, ConverterParameter=CambridgeBundle}" />
                    <RadioButton Content="{loc:Tr Mock_RandomSet}"
                                 GroupName="MockMode"
                                 VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBool}, ConverterParameter=RandomMix}" />
                </StackPanel>
            </Border>

            <!--  Bundle cards  -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding Bundles}"
                         SelectedItem="{Binding SelectedBundle, Mode=TwoWay}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource AnimatedSelectionListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{DynamicResource StrongTextBrush}" />
                                    <TextBlock Style="{StaticResource Caption}"
                                               Text="Listening · Reading · Writing · Speaking"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource OverlayLight20Brush}"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentHotBrush}"
                                               Text="{Binding SectionsLabel}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="4"
                       Style="{StaticResource MutedText}"
                       Text="{Binding StatusText}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Mock_StartExam}"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding StartCommand}" />
            </StackPanel>
        </Grid>

        <!--  Right: history  -->
        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,8,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Tr ReadIelts_History}" Style="{StaticResource H2}" />
                <Button Grid.Column="1"
                        Content="{loc:Tr Mock_Clear}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,4"
                        FontSize="12"
                        ToolTip="{loc:Tr Mock_ClearHistoryTooltip}"
                        Command="{Binding ClearHistoryCommand}" />
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding RecentAttempts}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource FlatListBoxItem}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenAttemptCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="Cambridge " /><Run Text="{Binding Book, Mode=OneWay}" />
                                        <Run Text=" Test " /><Run Text="{Binding TestNumber, Mode=OneWay}" />
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Border Background="{DynamicResource OverlayLight20Brush}"
                                                CornerRadius="4" Padding="5,1"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding IsPartial, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{loc:Tr Mock_Partial}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource AccentHotBrush}" />
                                        </Border>
                                        <TextBlock Style="{StaticResource Caption}"
                                                   Text="{Binding StartedAt, StringFormat='dd.MM HH:mm', Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource OverlayLight20Brush}"
                                        CornerRadius="8"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding OverallBand, Converter={StaticResource NullToVis}}">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentHotBrush}"
                                               Text="{Binding OverallBand, StringFormat='F1', Mode=OneWay}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
