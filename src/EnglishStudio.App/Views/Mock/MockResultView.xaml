<UserControl x:Class="EnglishStudio.App.Views.Mock.MockResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Mock"
             xmlns:rvm="clr-namespace:EnglishStudio.App.ViewModels.Reading"
             xmlns:rv="clr-namespace:EnglishStudio.App.Views.Reading"
             xmlns:lvm="clr-namespace:EnglishStudio.App.ViewModels.Listening"
             xmlns:lv="clr-namespace:EnglishStudio.App.Views.Listening"
             xmlns:wvm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
             xmlns:wv="clr-namespace:EnglishStudio.App.Views.Writing"
             xmlns:svm="clr-namespace:EnglishStudio.App.ViewModels.Speaking"
             xmlns:sv="clr-namespace:EnglishStudio.App.Views.Speaking"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MockResultViewModel}"
             d:DesignHeight="760" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />

        <!--  Секционный разбор переиспользует штатные Result-обёртки и их View  -->
        <DataTemplate DataType="{x:Type rvm:ReadingResultScreen}">
            <rv:ReadingResultView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type lvm:ListeningResultScreen}">
            <lv:ListeningResultView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type wvm:WritingResultScreen}">
            <wv:WritingResultView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type svm:SpeakingResultScreen}">
            <sv:SpeakingResultView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!--  Сводка-«сертификат» (видна, когда нет вложенного разбора)  -->
        <Grid Visibility="{Binding IsOverviewVisible, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="‹ В меню"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding BackToHubCommand}" />
                <TextBlock Grid.Column="1"
                           Style="{StaticResource H2}"
                           HorizontalAlignment="Center"
                           Text="Результат экзамена" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="820" HorizontalAlignment="Center">

                    <!--  Overall band card  -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ExamTitle}" Style="{StaticResource H1}" />
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,6,0,0"
                                           Text="{Binding DateLabel, Mode=OneWay}" />
                                <Border Background="{DynamicResource OverlayLight20Brush}"
                                        CornerRadius="6"
                                        Padding="9,3"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentHotBrush}"
                                               Text="{Binding CompletionLabel, Mode=OneWay}" />
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentMidBrush}"
                                    CornerRadius="14"
                                    Padding="30,16"
                                    VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource StrongTextBrush}"
                                               Text="OVERALL BAND" />
                                    <TextBlock FontSize="52"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource StrongTextBrush}"
                                               Text="{Binding OverallLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!--  Per-section bands + breakdown  -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Секции" Style="{StaticResource H3}" Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MockResultSectionRow}">
                                        <Border Background="{DynamicResource OverlayLight13Brush}"
                                                CornerRadius="8"
                                                Padding="14,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource StrongTextBrush}" />
                                                    <TextBlock Style="{StaticResource Caption}"
                                                               Margin="0,2,0,0"
                                                               Text="{Binding StatusLabel, Mode=OneWay}" />
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource OverlayLight20Brush}"
                                                        CornerRadius="8"
                                                        Padding="14,6"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentHotBrush}"
                                                               Text="{Binding BandLabel, Mode=OneWay}" />
                                                </Border>

                                                <Button Grid.Column="2"
                                                        Content="Разобрать"
                                                        Style="{StaticResource FlatButton}"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{Binding CanReview}"
                                                        Command="{Binding DataContext.OpenBreakdownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource MutedText}"
                               Text="{Binding StatusText}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Вложенный секционный разбор  -->
        <ContentControl Content="{Binding CurrentScreen}" />
    </Grid>
</UserControl>
