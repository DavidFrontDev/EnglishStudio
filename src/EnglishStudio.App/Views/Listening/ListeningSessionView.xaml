<UserControl x:Class="EnglishStudio.App.Views.Listening.ListeningSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Listening"
             xmlns:lsn="clr-namespace:EnglishStudio.App.Views.Listening"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ListeningSessionViewModel}"
             d:DesignHeight="720" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/EnglishStudio.App;component/Views/Listening/CardTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <lsn:CardLayoutTemplateSelector x:Key="CardSelector"
                                            Anketa="{StaticResource AnketaCardTemplate}"
                                            Table="{StaticResource TableCardTemplate}"
                                            Comparison="{StaticResource ComparisonCardTemplate}"
                                            Cascade="{StaticResource CascadeCardTemplate}"
                                            CascadeImage="{StaticResource CascadeImageCardTemplate}"
                                            Choice="{StaticResource ChoiceCardTemplate}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Top bar  -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TestTitle}" Style="{StaticResource H2}" />
                    <TextBlock Text="{Binding CardPositionLabel}" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource OverlayDark27Brush}"
                        BorderBrush="{DynamicResource OverlayLight20Brush}"
                        BorderThickness="1" CornerRadius="6" Padding="14,6" Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding TimerVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱  " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TimerLabel}" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Caption}" Text="{Binding ProgressLabel}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <Button Content="{loc:Tr Listening_Cancel}" Style="{StaticResource FlatButton}" Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Audio player bar  -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10"
                Visibility="{Binding AudioAvailable, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="44" Margin="0,0,8,0"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding PlayPauseCommand}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="❚❚" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <Button Grid.Column="1" Content="↺" Width="40" Margin="0,0,12,0"
                        Style="{StaticResource FlatButton}" Command="{Binding ReplayCommand}"
                        ToolTip="{loc:Tr Listening_ReplayTooltip}" />

                <Slider Grid.Column="2" VerticalAlignment="Center"
                        Minimum="0" Maximum="1"
                        Value="{Binding ProgressFraction, Mode=TwoWay}"
                        IsEnabled="{Binding CanSeek}" />

                <TextBlock Grid.Column="3" Text="{Binding AudioTimeLabel}"
                           FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{DynamicResource MutedTextBrush}" />

                <TextBlock Grid.Column="4" Text="🔊" VerticalAlignment="Center"
                           FontSize="15" Margin="16,0,6,0"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <Slider Grid.Column="5" Width="92" VerticalAlignment="Center"
                        Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                        Value="{Binding Volume, Mode=TwoWay}"
                        ToolTip="{loc:Tr Listening_VolumeTooltip}" />

                <Button Grid.Column="6" Margin="12,0,0,0"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ToggleTranscriptCommand}"
                        Visibility="{Binding TranscriptAvailable, Converter={StaticResource BoolToVis}}"
                        ToolTip="{loc:Tr Listening_ShowTranscriptTooltip}">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{loc:Tr Listening_Transcript}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowTranscript}" Value="True">
                                        <Setter Property="Text" Value="{loc:Tr Listening_HideTranscript}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!--  Current card (+ transcript overlay)  -->
        <Grid Grid.Row="2">
            <Border Style="{StaticResource Card}">
                <ContentControl Content="{Binding CurrentCard}" ContentTemplateSelector="{StaticResource CardSelector}" />
            </Border>
            <Border Style="{StaticResource Card}"
                    Background="{DynamicResource WindowBaseBrush}"
                    Visibility="{Binding ShowTranscript, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Listening_TranscriptHeading}" Style="{StaticResource H3}" Margin="0,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding CurrentTranscript}" TextWrapping="Wrap"
                                   LineHeight="24" FontSize="14" Foreground="{DynamicResource PrimaryTextBrush}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!--  Card indicator  -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding Cards}" Margin="0,10,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="34" Height="30" Margin="3,0"
                            Command="{Binding DataContext.JumpToCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource OverlayLight13Brush}"
                                                    BorderBrush="{DynamicResource OverlayLight20Brush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="{Binding CardNumber}" FontSize="12" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHotBrush}" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentHotBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  Bottom nav  -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Tr Listening_Back}" Style="{StaticResource FlatButton}" Command="{Binding PrevCardCommand}" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource MutedText}" Text="{Binding CardPositionLabel}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="{loc:Tr Listening_Forward}" Style="{StaticResource FlatButton}" Margin="0,0,8,0" Command="{Binding NextCardCommand}" />
                <Button Content="{loc:Tr Listening_Finish}" Style="{StaticResource AccentButton}" Command="{Binding FinishCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
