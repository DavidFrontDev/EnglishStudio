<UserControl x:Class="EnglishStudio.App.Views.Listening.ListeningHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Listening"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ListeningHubViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="380" />
            <ColumnDefinition Width="1*" MinWidth="280" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🎧 IELTS Listening" Style="{StaticResource H1}" Margin="0,0,0,12" />

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding Tests}"
                         SelectedItem="{Binding SelectedTest, Mode=TwoWay}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource AnimatedSelectionListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Style="{StaticResource Caption}" Text="{Binding Code}" />
                                        <TextBlock Style="{StaticResource Caption}" Text="  ·  " />
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="{Binding QuestionCount, Mode=OneWay}" />
                                            <Run Text="{loc:Tr Listening_Questions}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource OverlayLight13Brush}"
                                        CornerRadius="6" Padding="8,3" VerticalAlignment="Center"
                                        Visibility="{Binding LastBand, Converter={StaticResource NullToVis}}">
                                    <TextBlock Foreground="{DynamicResource AccentHotBrush}" FontWeight="SemiBold">
                                        <Run Text="Band " /><Run Text="{Binding LastBand, StringFormat='F1', Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="2" Style="{StaticResource MutedText}" Text="{Binding StatusText}"
                       Margin="0,8,0,0" TextWrapping="Wrap" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Listening_Training}" Style="{StaticResource FlatButton}" Margin="0,0,8,0"
                        Command="{Binding StartTrainingCommand}" />
                <Button Content="{loc:Tr Listening_Exam40}" Style="{StaticResource AccentButton}"
                        Command="{Binding StartExamCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,8,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Tr Listening_History}" Style="{StaticResource H2}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="{loc:Tr Listening_ClearHistory}" Style="{StaticResource FlatButton}"
                        Command="{Binding ClearHistoryCommand}" VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding RecentAttempts}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource FlatListBoxItem}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenAttemptCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TestTitle}" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource Caption}" Text="  ·  " />
                                    <TextBlock Style="{StaticResource Caption}">
                                        <Run Text="Band " /><Run Text="{Binding BandEstimate, StringFormat='F1', Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                                    <Run Text="{Binding RawScore, Mode=OneWay}" />
                                    <Run Text=" / 40  ·  " />
                                    <Run Text="{Binding StartedAt, StringFormat='dd.MM HH:mm', Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
