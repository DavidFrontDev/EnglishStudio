<UserControl x:Class="EnglishStudio.App.Views.Listening.GapComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             VerticalAlignment="Bottom">
    <!-- Compact inline letter-picker for cascad_Image gaps. The placeholder shows the question
         number ("26") in accent colour until the user picks a letter from A/B/C/... -->
    <Grid Width="76" HorizontalAlignment="Left" VerticalAlignment="Bottom">
        <ComboBox x:Name="Picker"
                  Style="{StaticResource FlatComboBox}"
                  MinHeight="22"
                  Padding="6,1"
                  FontWeight="SemiBold"
                  HorizontalContentAlignment="Center">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Display}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock x:Name="NumberText"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   FontSize="12"
                   Foreground="{DynamicResource AccentHotBrush}" />
    </Grid>
</UserControl>
