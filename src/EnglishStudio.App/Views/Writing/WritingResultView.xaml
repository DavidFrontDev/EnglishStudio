<UserControl x:Class="EnglishStudio.App.Views.Writing.WritingResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:WritingResultScreen}"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="‹ К списку тестов"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding BackCommand}" />
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Style="{StaticResource H2}"
                       Text="Результат теста" />
            <Button Grid.Column="2"
                    Content="🔄 Перезапустить AI"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding Result.ReevaluateAllCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding Result}">

                <!-- Combined band card -->
                <Border Style="{StaticResource Card}"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasCombinedBand, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Итоговая оценка Writing" Style="{StaticResource H2}" />
                            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap">
                                Расчёт по официальной IELTS-формуле: Task 1 имеет вес ⅓, Task 2 — ⅔. Округление до ближайшего 0.5.
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{DynamicResource AccentMidBrush}"
                                CornerRadius="12"
                                Padding="22,12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           Text="OVERALL BAND" />
                                <TextBlock FontSize="36"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           Text="{Binding CombinedBand, StringFormat='F1', Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Task 1 panel -->
                <ContentControl Content="{Binding Task1}" Margin="0,0,0,12">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:WritingAttemptResult}">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource H3}">
                                                <Run Text="{Binding KindLabel, Mode=OneWay}" /><Run Text=" — " /><Run Text="{Binding TaskCode, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                                                <Run Text="{Binding WordCount, Mode=OneWay}" /><Run Text=" слов" /><Run Text="    ⏱ Время прохождения: " /><Run Text="{Binding DurationDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource OverlayLight20Brush}"
                                                CornerRadius="8"
                                                Padding="14,6"
                                                Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Band" />
                                                <TextBlock FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentHotBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandOverall, StringFormat='F1', Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <UniformGrid Columns="4" Margin="0,0,0,12"
                                                 Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="0,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Task" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandTaskAchievement, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Cohesion" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandCoherence, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Lexical" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandLexical, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,0,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Grammar" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandGrammar, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Background="{DynamicResource OverlayLight13Brush}"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Комментарий (RU)" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                                            <TextBlock Text="{Binding FeedbackRu}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                            <TextBlock Text="Комментарий (EN)" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                                            <TextBlock Text="{Binding FeedbackEn}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Issues}"
                                                  Margin="0,0,0,12"
                                                  Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource OverlayLight13Brush}"
                                                        CornerRadius="6"
                                                        Padding="10,8"
                                                        Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{DynamicResource AccentMidBrush}"
                                                                    CornerRadius="4"
                                                                    Padding="6,2"
                                                                    Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="{DynamicResource StrongTextBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Quote}"
                                                                       Foreground="{DynamicResource StrongTextBrush}"
                                                                       FontStyle="Italic"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ExplanationRu}"
                                                                   Style="{StaticResource MutedText}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Suggestion}"
                                                                   Foreground="{DynamicResource AccentHotBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- User answer -->
                                    <Expander Header="Ваш ответ"
                                              Margin="0,0,0,8"
                                              Foreground="{DynamicResource StrongTextBrush}">
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding UserText}" Style="{StaticResource BodyText}" TextWrapping="Wrap" />
                                        </Border>
                                    </Expander>

                                    <!-- Model answer toggle -->
                                    <Button Style="{StaticResource FlatButton}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding ToggleModelAnswerCommand}"
                                            Visibility="{Binding HasModelAnswer, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📘 Показать эталон band " />
                                            <TextBlock Text="{Binding ModelAnswerBand, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>
                                    <Border Background="{DynamicResource OverlayLight20Brush}"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,6,0,0"
                                            Visibility="{Binding ShowModelAnswer, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Эталонный ответ band "
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHotBrush}" />
                                                <TextBlock Text="{Binding ModelAnswerBand, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHotBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ModelAnswerText}"
                                                       Style="{StaticResource BodyText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Task 2 panel (same template) -->
                <ContentControl Content="{Binding Task2}" Margin="0,0,0,12">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:WritingAttemptResult}">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource H3}">
                                                <Run Text="{Binding KindLabel, Mode=OneWay}" /><Run Text=" — " /><Run Text="{Binding TaskCode, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                                                <Run Text="{Binding WordCount, Mode=OneWay}" /><Run Text=" слов" /><Run Text="    ⏱ Время прохождения: " /><Run Text="{Binding DurationDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource OverlayLight20Brush}"
                                                CornerRadius="8"
                                                Padding="14,6"
                                                Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Band" />
                                                <TextBlock FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentHotBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandOverall, StringFormat='F1', Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <UniformGrid Columns="4" Margin="0,0,0,12"
                                                 Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="0,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Task" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandTaskAchievement, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Cohesion" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandCoherence, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,4,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Lexical" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandLexical, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Margin="4,0,0,0" Padding="8,6">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center" Text="Grammar" />
                                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource StrongTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Text="{Binding BandGrammar, StringFormat='F1', Mode=OneWay, FallbackValue='—'}" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Background="{DynamicResource OverlayLight13Brush}"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Комментарий (RU)" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                                            <TextBlock Text="{Binding FeedbackRu}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                            <TextBlock Text="Комментарий (EN)" FontWeight="SemiBold" Foreground="{DynamicResource StrongTextBrush}" />
                                            <TextBlock Text="{Binding FeedbackEn}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Issues}"
                                                  Margin="0,0,0,12"
                                                  Visibility="{Binding HasBands, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource OverlayLight13Brush}"
                                                        CornerRadius="6"
                                                        Padding="10,8"
                                                        Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{DynamicResource AccentMidBrush}"
                                                                    CornerRadius="4"
                                                                    Padding="6,2"
                                                                    Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="{DynamicResource StrongTextBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Quote}"
                                                                       Foreground="{DynamicResource StrongTextBrush}"
                                                                       FontStyle="Italic"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ExplanationRu}"
                                                                   Style="{StaticResource MutedText}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding Suggestion}"
                                                                   Foreground="{DynamicResource AccentHotBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Expander Header="Ваш ответ"
                                              Margin="0,0,0,8"
                                              Foreground="{DynamicResource StrongTextBrush}">
                                        <Border Background="{DynamicResource OverlayLight13Brush}" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding UserText}" Style="{StaticResource BodyText}" TextWrapping="Wrap" />
                                        </Border>
                                    </Expander>

                                    <Button Style="{StaticResource FlatButton}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding ToggleModelAnswerCommand}"
                                            Visibility="{Binding HasModelAnswer, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📘 Показать эталон band " />
                                            <TextBlock Text="{Binding ModelAnswerBand, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>
                                    <Border Background="{DynamicResource OverlayLight20Brush}"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,6,0,0"
                                            Visibility="{Binding ShowModelAnswer, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Эталонный ответ band "
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHotBrush}" />
                                                <TextBlock Text="{Binding ModelAnswerBand, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHotBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ModelAnswerText}"
                                                       Style="{StaticResource BodyText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <TextBlock Style="{StaticResource MutedText}"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
