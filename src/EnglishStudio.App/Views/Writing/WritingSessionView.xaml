<UserControl x:Class="EnglishStudio.App.Views.Writing.WritingSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
             xmlns:ctrls="clr-namespace:EnglishStudio.App.Views.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:WritingSessionViewModel}"
             d:DesignHeight="700" d:DesignWidth="1200"
             Loaded="OnLoaded"
             DataContextChanged="OnDataContextChanged">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Style for task tab toggle buttons -->
        <Style x:Key="TaskTabButton" TargetType="Button">
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource StrongTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder"
                                Background="{DynamicResource OverlayLight13Brush}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource OverlayLight20Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="Foreground" Value="{DynamicResource StrongTextBrush}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{DynamicResource AccentMidBrush}"
                                        CornerRadius="8,8,0,0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Top header: title + timer + finish  -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="‹ Отмена"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding CancelCommand}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding TestTitle}" Style="{StaticResource H2}" />
            </StackPanel>

            <Border Grid.Column="2" Background="{DynamicResource OverlayLight20Brush}" CornerRadius="8" Padding="14,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏱" FontSize="16" Margin="0,0,6,0" Foreground="{DynamicResource StrongTextBrush}" />
                    <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource StrongTextBrush}" />
                    <TextBlock Text="  /  60:00" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Button Grid.Column="3"
                    Content="Завершить тест"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding FinishCommand}" />
        </Grid>

        <!--  Tab strip  -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
            <Button Command="{Binding SwitchToTask1Command}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource TaskTabButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTask1Current}" Value="True">
                                <Setter Property="Tag" Value="active" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Task 1" />
                    <TextBlock Text="  ·  " />
                    <TextBlock>
                        <Run Text="{Binding Task1.WordCount, Mode=OneWay, FallbackValue='0'}" />
                        <Run Text="/" />
                        <Run Text="{Binding Task1.MinWords, Mode=OneWay, FallbackValue='150'}" />
                    </TextBlock>
                    <TextBlock Text=" ✓" Foreground="{DynamicResource AccentHotBrush}"
                               Visibility="{Binding Task1.MeetsWordCount, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Button>

            <Button Command="{Binding SwitchToTask2Command}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource TaskTabButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTask2Current}" Value="True">
                                <Setter Property="Tag" Value="active" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Task 2" />
                    <TextBlock Text="  ·  " />
                    <TextBlock>
                        <Run Text="{Binding Task2.WordCount, Mode=OneWay, FallbackValue='0'}" />
                        <Run Text="/" />
                        <Run Text="{Binding Task2.MinWords, Mode=OneWay, FallbackValue='250'}" />
                    </TextBlock>
                    <TextBlock Text=" ✓" Foreground="{DynamicResource AccentHotBrush}"
                               Visibility="{Binding Task2.MeetsWordCount, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!--  Body: current task 2-pane  -->
        <Border Grid.Row="2" Background="{DynamicResource OverlayLight13Brush}" CornerRadius="0,8,8,8" Padding="14">
            <Grid DataContext="{Binding CurrentTask}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="380" />
                    <ColumnDefinition Width="1*" MinWidth="380" />
                </Grid.ColumnDefinitions>

                <!-- Left: image (if any) + prompt -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Caption}">
                                <Run Text="{Binding KindLabel, Mode=OneWay}" />
                                <Run Text="  ·  ≥" />
                                <Run Text="{Binding MinWords, Mode=OneWay}" />
                                <Run Text=" слов  ·  ~" />
                                <Run Text="{Binding RecommendedMinutes, Mode=OneWay}" />
                                <Run Text=" мин" />
                            </TextBlock>

                            <ctrls:ZoomableImage Source="{Binding ImagePath}"
                                                 Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 MaxImageHeight="480"
                                                 HorizontalAlignment="Left"
                                                 Margin="0,12,0,12"
                                                 Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="{Binding PromptText}"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right: textbox -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Ваш ответ" Style="{StaticResource H3}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1"
                                 x:Name="AnswerTextBox"
                                 Text="{Binding UserText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FlatTextBox}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 SpellCheck.IsEnabled="True"
                                 Language="en-GB"
                                 VerticalContentAlignment="Top" />
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <Border Background="{DynamicResource OverlayLight13Brush}"
                                    CornerRadius="6"
                                    Padding="10,4">
                                <TextBlock Foreground="{DynamicResource StrongTextBrush}" FontWeight="SemiBold">
                                    <Run Text="{Binding WordCount, Mode=OneWay}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding MinWords, Mode=OneWay}" />
                                    <Run Text=" слов" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Style="{StaticResource MutedText}"
                   Text="{Binding StatusText}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
