<UserControl x:Class="EnglishStudio.App.Views.Writing.BandTrendChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DesignHeight="260" d:DesignWidth="600"
             Background="Transparent"
             SizeChanged="OnSizeChanged">
    <Grid>
        <Canvas x:Name="PlotCanvas" ClipToBounds="True" />
        <TextBlock x:Name="EmptyLabel"
                   Text="{loc:Tr Writing_NoChartData}"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource MutedTextBrush}"
                   FontSize="13" />
    </Grid>
</UserControl>
