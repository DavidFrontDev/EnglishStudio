<UserControl x:Class="EnglishStudio.App.Views.Writing.WritingHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
             xmlns:local="clr-namespace:EnglishStudio.App.Views.Writing"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:WritingHistoryViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: back + title -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="‹ Назад"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding BackCommand}" />

            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="📊 История Writing" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource MutedText}"
                           Text="Прогресс band'а по неделям + детальный разбор попыток"
                           Margin="0,2,0,0" />
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Style="{StaticResource MutedText}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Visibility="{Binding LastAttemptAt, Converter={StaticResource NullToVis}}">
                <Run Text="Последняя попытка: " />
                <Run Text="{Binding LastAttemptAt, StringFormat='dd.MM.yyyy HH:mm', Mode=OneWay}" />
            </TextBlock>
        </Grid>

        <!-- Stats cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Попыток" />
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource StrongTextBrush}"
                               Text="{Binding TotalAttempts, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Caption}">
                        <Run Text="из них завершено: " />
                        <Run Text="{Binding CompletedAttempts, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Средний band" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentHotBrush}"
                                   Text="{Binding AverageBand, StringFormat='F1', TargetNullValue='—', Mode=OneWay}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="по завершённым тестам" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Лучший band" />
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource AccentHotBrush}"
                               Text="{Binding BestBand, StringFormat='F1', TargetNullValue='—', Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Caption}" Text="из всех попыток" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Слов написано" />
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource StrongTextBrush}"
                               Text="{Binding TotalWords, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Caption}" Text="суммарно" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Время за столом" />
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource StrongTextBrush}"
                               Text="{Binding TotalTimeSpentDisplay, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Caption}" Text="суммарно" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Chart -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Style="{StaticResource H3}" Text="Прогресс band'а по неделям" Margin="0,0,0,8" />
                <local:BandTrendChart Points="{Binding TrendPoints}"
                                      Height="220" />
            </StackPanel>
        </Border>

        <!-- Detail list -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource H3}" Text="Все попытки" Margin="0,0,0,8" />

                <!-- Table header -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="2.4*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Caption}" Text="Дата" />
                    <TextBlock Grid.Column="1" Style="{StaticResource Caption}" Text="Тест" />
                    <TextBlock Grid.Column="2" Style="{StaticResource Caption}" Text="Задание" />
                    <TextBlock Grid.Column="3" Style="{StaticResource Caption}" Text="Слов" />
                    <TextBlock Grid.Column="4" Style="{StaticResource Caption}" Text="Время" />
                    <TextBlock Grid.Column="5" Style="{StaticResource Caption}" Text="TR" ToolTip="Task Achievement" />
                    <TextBlock Grid.Column="6" Style="{StaticResource Caption}" Text="CC" ToolTip="Coherence &amp; Cohesion" />
                    <TextBlock Grid.Column="7" Style="{StaticResource Caption}" Text="LR" ToolTip="Lexical Resource" />
                    <TextBlock Grid.Column="8" Style="{StaticResource Caption}" Text="GRA" ToolTip="Grammatical Range &amp; Accuracy" />
                    <TextBlock Grid.Column="9" Style="{StaticResource Caption}" Text="Band"
                               Foreground="{DynamicResource AccentHotBrush}" FontWeight="SemiBold" />
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Entries}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource FlatListBoxItem}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenAttemptCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="2.4*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding StartedAt, StringFormat='dd.MM.yyyy', Mode=OneWay}"
                                               Foreground="{DynamicResource StrongTextBrush}" />
                                    <TextBlock Text="{Binding StartedAt, StringFormat='HH:mm', Mode=OneWay}"
                                               Style="{StaticResource Caption}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TestSetTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource StrongTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TaskCode}" Style="{StaticResource Caption}" />
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Kind}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="3"
                                           Text="{Binding WordCount, Mode=OneWay}"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="4"
                                           Text="{Binding DurationSeconds, StringFormat='{}{0} сек', Mode=OneWay}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="5"
                                           Text="{Binding BandTaskAchievement, StringFormat='F1', TargetNullValue='—', Mode=OneWay}"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="6"
                                           Text="{Binding BandCoherence, StringFormat='F1', TargetNullValue='—', Mode=OneWay}"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="7"
                                           Text="{Binding BandLexical, StringFormat='F1', TargetNullValue='—', Mode=OneWay}"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="8"
                                           Text="{Binding BandGrammar, StringFormat='F1', TargetNullValue='—', Mode=OneWay}"
                                           Foreground="{DynamicResource StrongTextBrush}"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="9"
                                        Background="{DynamicResource OverlayLight20Brush}"
                                        CornerRadius="6"
                                        Padding="8,2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding BandOverall, Converter={StaticResource NullToVis}}">
                                    <TextBlock Text="{Binding BandOverall, StringFormat='F1', Mode=OneWay}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentHotBrush}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Loading / error overlay -->
        <Border Grid.RowSpan="4"
                Background="{DynamicResource OverlayLight20Brush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <TextBlock Text="Загрузка истории…" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource H2}" />
        </Border>
    </Grid>
</UserControl>
