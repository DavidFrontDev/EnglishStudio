<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.Writing.AiProcessingWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
                        mc:Ignorable="d"
                        d:DataContext="{d:DesignInstance Type=vm:AiProcessingViewModel}"
                        Title="{loc:Tr Writing_AiWindowTitle}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="460" Height="260"
                        ResizeMode="NoResize"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None"
                        WindowStartupLocation="CenterOwner"
                        ShowInTaskbar="False">
    <Grid>
        <!--  Background — same family as the main window  -->
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.3,0.2" GradientOrigin="0.3,0.2" RadiusX="1.4" RadiusY="1.6">
                    <GradientStop Offset="0" Color="{DynamicResource AccentHotColor}" />
                    <GradientStop Offset="0.4" Color="{DynamicResource AccentMidColor}" />
                    <GradientStop Offset="0.9" Color="{DynamicResource AccentDeepColor}" />
                    <GradientStop Offset="1" Color="{DynamicResource AccentEdgeColor}" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Border Margin="22,18,22,22"
                Background="{DynamicResource OverlayLight13Brush}"
                BorderBrush="{DynamicResource OverlayLight20Brush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Spinner: rotating arc  -->
                <Grid Grid.Column="0" Width="64" Height="64" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Ellipse Width="64" Height="64"
                             Stroke="{DynamicResource OverlayLight20Brush}"
                             StrokeThickness="5" />
                    <Path Stroke="{DynamicResource AccentHotBrush}"
                          StrokeThickness="5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          RenderTransformOrigin="0.5,0.5"
                          Data="M 32,4 A 28,28 0 0 1 60,32">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="ArcRotation" Angle="0" />
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="ArcRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:1.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Tr Writing_AiEvaluating}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource StrongTextBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <TextBlock Text="⏱"
                                   FontSize="14"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource StrongTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Tr Writing_ElapsedSinceSubmit}"
                                   Foreground="{DynamicResource CaptionTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</appshell:ChromedWindow>
