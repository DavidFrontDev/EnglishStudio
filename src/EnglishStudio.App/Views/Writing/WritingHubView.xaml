<UserControl x:Class="EnglishStudio.App.Views.Writing.WritingHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:EnglishStudio.App.ViewModels.Writing"
             xmlns:conv="clr-namespace:EnglishStudio.App.Converters"
             xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:WritingHubViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="520" />
            <ColumnDefinition Width="1*" MinWidth="280" />
        </Grid.ColumnDefinitions>

        <!--  Left: TestSet cards + actions  -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{loc:Tr Writing_HubTitle}" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="{loc:Tr Writing_HubDescription}" />

                <!-- AI unavailable warning -->
                <Border Background="{DynamicResource OverlayLight13Brush}"
                        BorderBrush="{DynamicResource WarningBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8"
                        Margin="0,10,0,0"
                        Visibility="{Binding IsAiUnavailable, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{loc:Tr Hub_AiUnavailable}"
                               Style="{StaticResource MutedText}"
                               Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Filter bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource OverlayLight13Brush}"
                    CornerRadius="8"
                    Padding="10,8"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{loc:Tr Writing_Filters}"
                               Style="{StaticResource Caption}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />

                    <StackPanel Grid.Column="1" Margin="0,0,6,0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Tr Writing_FilterBook}" />
                        <ComboBox ItemsSource="{Binding AvailableBooks}"
                                  SelectedValuePath="Token"
                                  SelectedValue="{Binding SelectedBook, Mode=TwoWay}"
                                  Style="{StaticResource FlatComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="6,0,6,0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Tr Writing_FilterTaskType}" />
                        <ComboBox ItemsSource="{Binding AvailableChartTypes}"
                                  SelectedItem="{Binding SelectedChartType, Mode=TwoWay}"
                                  Style="{StaticResource FlatComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="6,0,6,0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Tr Writing_FilterProgress}" />
                        <ComboBox ItemsSource="{Binding AvailableCompletionFilters}"
                                  SelectedValuePath="Token"
                                  SelectedValue="{Binding SelectedCompletion, Mode=TwoWay}"
                                  Style="{StaticResource FlatComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Column="4"
                            Background="{DynamicResource OverlayLight20Brush}"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="8,14,6,0"
                            VerticalAlignment="Center">
                        <TextBlock Foreground="{DynamicResource StrongTextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12">
                            <Run Text="{Binding VisibleCount, Mode=OneWay}" />
                            <Run Text="{loc:Tr Writing_Of}" />
                            <Run Text="{Binding TestSets.Count, Mode=OneWay}" />
                        </TextBlock>
                    </Border>

                    <Button Grid.Column="5"
                            Content="{loc:Tr Writing_Reset}"
                            Style="{StaticResource FlatButton}"
                            Padding="10,4"
                            FontSize="12"
                            Margin="0,14,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding ResetFiltersCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding TestSetsView}"
                         SelectedItem="{Binding SelectedTestSet, Mode=TwoWay}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource AnimatedSelectionListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{DynamicResource StrongTextBrush}" />
                                    <TextBlock Style="{StaticResource Caption}"
                                               Text="{Binding Attribution}"
                                               Margin="0,2,0,6" />

                                    <Grid Margin="0,4,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0"
                                                Background="{DynamicResource OverlayLight13Brush}"
                                                CornerRadius="4" Padding="6,2" Margin="0,0,8,2">
                                            <TextBlock Text="{Binding Task1ChartType}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentHotBrush}" />
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Task1PromptPreview}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="32"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Border Grid.Row="1" Grid.Column="0"
                                                Background="{DynamicResource OverlayLight13Brush}"
                                                CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="Task 2"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentHotBrush}" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding Task2PromptPreview}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="32"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Style="{StaticResource Caption}">
                                            <Run Text="{loc:Tr Writing_AttemptsPrefixColon}" /><Run Text="{Binding CompletedAttempts, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource OverlayLight20Brush}"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding LastOverallBand, Converter={StaticResource NullToVis}}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Caption}" Text="Last" HorizontalAlignment="Center" />
                                        <TextBlock FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentHotBrush}"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding LastOverallBand, StringFormat='F1', Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="3"
                       Style="{StaticResource MutedText}"
                       Text="{Binding StatusText}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                <Button Content="{loc:Tr Writing_StartTest}"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding StartCommand}" />
            </StackPanel>
        </Grid>

        <!--  Right: history  -->
        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,8,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Tr Writing_History}" Style="{StaticResource H2}" />
                <Button Grid.Column="1"
                        Content="{loc:Tr Writing_Details}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,4"
                        FontSize="12"
                        Margin="0,0,6,0"
                        ToolTip="{loc:Tr Writing_DetailsTooltip}"
                        Command="{Binding ShowHistoryCommand}" />
                <Button Grid.Column="2"
                        Content="{loc:Tr Writing_Clear}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,4"
                        FontSize="12"
                        ToolTip="{loc:Tr Writing_ClearTooltip}"
                        Command="{Binding ClearHistoryCommand}" />
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding RecentAttempts}"
                         Style="{StaticResource FlatListBox}"
                         ItemContainerStyle="{StaticResource FlatListBoxItem}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenAttemptCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TaskCode}" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource Caption}" Text="  ·  " />
                                    <TextBlock Style="{StaticResource Caption}"
                                               Visibility="{Binding BandOverall, Converter={StaticResource NullToVis}}">
                                        <Run Text="Band " /><Run Text="{Binding BandOverall, StringFormat='F1', Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0">
                                    <Run Text="{Binding WordCount, Mode=OneWay}" />
                                    <Run Text="{loc:Tr Writing_WordsMiddleDot}" />
                                    <Run Text="{Binding StartedAt, StringFormat='dd.MM HH:mm', Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
