<appshell:ChromedWindow x:Class="EnglishStudio.App.Views.Dialogs.ImageZoomWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:appshell="clr-namespace:EnglishStudio.App.Shell"
                        xmlns:loc="clr-namespace:EnglishStudio.App.Localization"
                        mc:Ignorable="d"
                        Title="{loc:Tr Dialog_ImageZoomTitle}"
                        Style="{StaticResource ChromedWindowStyle}"
                        Width="840" Height="640"
                        MinWidth="360" MinHeight="280"
                        AllowsTransparency="True"
                        Background="Transparent"
                        WindowStyle="None"
                        WindowStartupLocation="CenterScreen"
                        ShowInTaskbar="False">
    <Border CornerRadius="0,0,10,10" Background="{DynamicResource ImageBackdropBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Image x:Name="ZoomImage"
                       Stretch="Fill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </ScrollViewer>

            <!--  Zoom slider: 50%…200%, по умолчанию 120%  -->
            <Border Grid.Row="1" Background="#22FFFFFF" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{loc:Tr Dialog_ZoomScale}"
                               Foreground="{DynamicResource ImageBackdropTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Slider Grid.Column="1"
                            x:Name="ZoomSlider"
                            Minimum="0.5"
                            Maximum="2.0"
                            Value="0.5"
                            SmallChange="0.1"
                            LargeChange="0.2"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="OnZoomChanged" />
                    <TextBlock Grid.Column="2"
                               x:Name="ZoomLabel"
                               Text="50%"
                               Foreground="{DynamicResource ImageBackdropTextBrush}"
                               FontWeight="SemiBold"
                               MinWidth="52"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</appshell:ChromedWindow>
