<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Forest — тёмно-зелёная тема. Overlay-блоки совпадают с DarkBlue (тёмная база).
        Набор ключей идентичен остальным палитрам.
    -->

    <!--  ════════ Window background / chrome ════════  -->
    <SolidColorBrush x:Key="WindowBaseBrush" Color="#14241a" />

    <Color x:Key="AccentHotColor">#4caf50</Color>
    <Color x:Key="AccentMidColor">#388e3c</Color>
    <Color x:Key="AccentDeepColor">#2e6b32</Color>
    <Color x:Key="AccentEdgeColor">#14351a</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#388e3c" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#4caf50" />

    <Color x:Key="ChromeStartColor">#1d3326</Color>
    <Color x:Key="ChromeEndColor">#102017</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <!--  ════════ Text ════════  -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#DDE7DD" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#EAF3EA" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#A9C0AC" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#8FA992" />

    <!--  ════════ Semantic ════════  -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#7CFFA0" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF6B6B" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFD54F" />
    <SolidColorBrush x:Key="InfoBrush" Color="#7FD8FF" />

    <!--  ════════ CTA (Accent button) ════════  -->
    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="#4caf50" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#0b2310" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#5cc25f" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#3d9440" />

    <!--  ════════ Overlays — как в DarkBlue ════════  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2CFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CCFFFFFF" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44000000" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99000000" />

    <!--  ════════ Selection ════════  -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#444caf50" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#334caf50" />

    <!--  ════════ Pills (CEFR badges) — как в DarkBlue ════════  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#5CB85C" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#3F9C3F" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3D8FD1" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#A24CC4" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7A1FA2" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#6A7682" />

    <!--  On-accent text (на зелёном пилле)  -->
    <SolidColorBrush x:Key="OnAccentBrush" Color="#0b2310" />

    <!--  Surfaces  -->
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF14301f" />

    <!--  Speaking-таймеры (тёмные чипы под белые цифры)  -->
    <SolidColorBrush x:Key="NotePanelBrush" Color="#1b3a2a" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#a0e0b8" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#5C2A2A" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#FFB7B7" />

    <!--  Record button  -->
    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <!--  Image lightbox  -->
    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <!--  Selection gradients (глубокий акцент — светлый текст)  -->
    <Color x:Key="SelectedItemStartColor">#2f7d3a</Color>
    <Color x:Key="SelectedItemMidColor">#1f5a28</Color>
    <Color x:Key="SelectedItemEndColor">#123418</Color>
    <Color x:Key="SidebarSelectStartColor">#2e7d3a</Color>
    <Color x:Key="SidebarSelectEndColor">#1c5226</Color>
    <Color x:Key="ShimmerColor">#554caf50</Color>

</ResourceDictionary>
