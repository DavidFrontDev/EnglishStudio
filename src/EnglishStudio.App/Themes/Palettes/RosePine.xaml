<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Rosé Pine — мягкая тёмная тема с приглушённым ирисово-розовым акцентом.
        Тёмное семейство: overlay-блоки как в DarkBlue. Набор ключей идентичен всем палитрам.
    -->

    <SolidColorBrush x:Key="WindowBaseBrush" Color="#191724" />

    <Color x:Key="AccentHotColor">#C4A7E7</Color>
    <Color x:Key="AccentMidColor">#A98FD0</Color>
    <Color x:Key="AccentDeepColor">#7E5FB0</Color>
    <Color x:Key="AccentEdgeColor">#26233A</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#A98FD0" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#C4A7E7" />

    <Color x:Key="ChromeStartColor">#1F1D2E</Color>
    <Color x:Key="ChromeEndColor">#191724</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0DEF4" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#F0EEF8" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#ADA9C4" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#968FB0" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#A3C9A8" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#EB6F92" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F6C177" />
    <SolidColorBrush x:Key="InfoBrush" Color="#9CCFD8" />

    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="#C4A7E7" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#191724" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#D0B8EE" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#B08FD8" />

    <!--  Overlays — как в DarkBlue (тёмная база)  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2CFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CCFFFFFF" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44000000" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99000000" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#44C4A7E7" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#33C4A7E7" />

    <!--  Pills — как в DarkBlue  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#5CB85C" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#3F9C3F" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3D8FD1" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#A24CC4" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7A1FA2" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#6A7682" />

    <SolidColorBrush x:Key="OnAccentBrush" Color="#191724" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF1F1D2E" />

    <SolidColorBrush x:Key="NotePanelBrush" Color="#2A2F48" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#B0BEE6" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#4A2F3A" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#EBA0B2" />

    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <Color x:Key="SelectedItemStartColor">#5A4A78</Color>
    <Color x:Key="SelectedItemMidColor">#433460</Color>
    <Color x:Key="SelectedItemEndColor">#2A2440</Color>
    <Color x:Key="SidebarSelectStartColor">#5A4A78</Color>
    <Color x:Key="SidebarSelectEndColor">#3E3056</Color>
    <Color x:Key="ShimmerColor">#55C4A7E7</Color>

</ResourceDictionary>
