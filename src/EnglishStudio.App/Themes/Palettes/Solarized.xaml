<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Solarized Dark (Ethan Schoonover). Тёмная тема — overlay-блоки совпадают с DarkBlue
        (светлый-альфа поверх тёмной базы). Набор ключей идентичен DarkBlue/Light.
    -->

    <!--  ════════ Window background / chrome ════════  -->
    <SolidColorBrush x:Key="WindowBaseBrush" Color="#002b36" />

    <Color x:Key="AccentHotColor">#2aa198</Color>
    <Color x:Key="AccentMidColor">#268bd2</Color>
    <Color x:Key="AccentDeepColor">#1c6a99</Color>
    <Color x:Key="AccentEdgeColor">#073642</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#268bd2" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#2aa198" />

    <Color x:Key="ChromeStartColor">#0a4250</Color>
    <Color x:Key="ChromeEndColor">#002b36</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <!--  ════════ Text ════════  -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#93a1a1" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#eee8d5" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#fdf6e3" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9aa6a6" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#8a999b" />

    <!--  ════════ Semantic (solarized-палитра) ════════  -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#859900" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#dc322f" />
    <SolidColorBrush x:Key="WarningBrush" Color="#b58900" />
    <SolidColorBrush x:Key="InfoBrush" Color="#268bd2" />

    <!--  ════════ CTA (Accent button) ════════  -->
    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="#2aa198" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#002b36" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#35b3aa" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#1f8077" />

    <!--  ════════ Overlays (glass / borders) — как в DarkBlue ════════  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2CFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CCFFFFFF" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44000000" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99000000" />

    <!--  ════════ Selection ════════  -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#442aa198" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#332aa198" />

    <!--  ════════ Pills (CEFR badges) — как в DarkBlue ════════  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#5CB85C" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#3F9C3F" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3D8FD1" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#A24CC4" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7A1FA2" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#6A7682" />

    <!--  On-accent text (на cyan-пилле) — тёмная база  -->
    <SolidColorBrush x:Key="OnAccentBrush" Color="#002b36" />

    <!--  Surfaces  -->
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF073642" />

    <!--  Speaking-таймеры (тёмные чипы под белые цифры)  -->
    <SolidColorBrush x:Key="NotePanelBrush" Color="#0a3a44" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#8fd0c8" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#5C2A2A" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#FFB7B7" />

    <!--  Record button  -->
    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <!--  Image lightbox  -->
    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <!--  Selection gradients (глубокий акцент — светлый текст)  -->
    <Color x:Key="SelectedItemStartColor">#1e6fa0</Color>
    <Color x:Key="SelectedItemMidColor">#155678</Color>
    <Color x:Key="SelectedItemEndColor">#0b3a4a</Color>
    <Color x:Key="SidebarSelectStartColor">#1c6a99</Color>
    <Color x:Key="SidebarSelectEndColor">#124d6e</Color>
    <Color x:Key="ShimmerColor">#552aa198</Color>

</ResourceDictionary>
