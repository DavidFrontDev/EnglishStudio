<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Sepia — тёплая светлая тема (кремовый фон). СВЕТЛОЕ семейство: overlay-блоки
        инвертированы как в Light (OverlayLight = чёрный-альфа затемняет, OverlayDark = белый-альфа).
        Набор ключей идентичен остальным палитрам.
    -->

    <!--  ════════ Window background / chrome ════════  -->
    <SolidColorBrush x:Key="WindowBaseBrush" Color="#F4ECD8" />

    <Color x:Key="AccentHotColor">#C08A4F</Color>
    <Color x:Key="AccentMidColor">#8B5E34</Color>
    <Color x:Key="AccentDeepColor">#6B4423</Color>
    <Color x:Key="AccentEdgeColor">#4A2F18</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#8B5E34" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#C08A4F" />

    <Color x:Key="ChromeStartColor">#FBF5E6</Color>
    <Color x:Key="ChromeEndColor">#E8DCC0</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <!--  ════════ Text (тёмно-коричневый на креме) ════════  -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#4A3B28" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#3A2E1E" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#2A2114" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#5E4D32" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#6E5C3C" />

    <!--  ════════ Semantic (как в Light — тёмные для светлого фона) ════════  -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706" />
    <SolidColorBrush x:Key="InfoBrush" Color="#0284C7" />

    <!--  ════════ CTA (Accent button) ════════  -->
    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="#8B5E34" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#FBF5E6" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#7A5230" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#6B4423" />

    <!--  ════════ Overlays — инвертированы как в Light ════════  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2C000000" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77000000" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99000000" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AA000000" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CC000000" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44FFFFFF" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99FFFFFF" />

    <!--  ════════ Selection ════════  -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#338B5E34" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#228B5E34" />

    <!--  ════════ Pills (CEFR badges) — как в Light ════════  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#22C55E" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#16A34A" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3B82F6" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#9333EA" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7E22CE" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#64748B" />

    <!--  On-accent text (тёмный на коричневом пилле)  -->
    <SolidColorBrush x:Key="OnAccentBrush" Color="#3A2A18" />

    <!--  Surfaces — светлый непрозрачный фон выпадающих списков  -->
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FFF7EFDD" />

    <!--  Speaking-таймеры: фон держим тёмным (поверх белые цифры)  -->
    <SolidColorBrush x:Key="NotePanelBrush" Color="#3E2C18" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#E0C088" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#5C2A2A" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#FFB7B7" />

    <!--  Record button  -->
    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <!--  Image lightbox — тёмный backdrop  -->
    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <!--  Selection gradients — БЛЕДНЫЙ тёплый акцент (тёмный текст читаем)  -->
    <Color x:Key="SelectedItemStartColor">#E8D9B8</Color>
    <Color x:Key="SelectedItemMidColor">#DCC79A</Color>
    <Color x:Key="SelectedItemEndColor">#D0B884</Color>
    <Color x:Key="SidebarSelectStartColor">#ECDFC4</Color>
    <Color x:Key="SidebarSelectEndColor">#DECBA0</Color>
    <Color x:Key="ShimmerColor">#558B5E34</Color>

</ResourceDictionary>
