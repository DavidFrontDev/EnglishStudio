<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Mocha — мягкая тёмная тема в пастельных тонах (по мотивам Catppuccin Mocha).
        Тёмное семейство: overlay-блоки как в DarkBlue. Набор ключей идентичен всем палитрам.
    -->

    <SolidColorBrush x:Key="WindowBaseBrush" Color="#1E1E2E" />

    <Color x:Key="AccentHotColor">#CBA6F7</Color>
    <Color x:Key="AccentMidColor">#A98FE0</Color>
    <Color x:Key="AccentDeepColor">#7E5FB0</Color>
    <Color x:Key="AccentEdgeColor">#313244</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#A98FE0" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#CBA6F7" />

    <Color x:Key="ChromeStartColor">#313244</Color>
    <Color x:Key="ChromeEndColor">#1E1E2E</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#CDD6F4" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#EEF0FB" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#B3BCD8" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#9AA3C0" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#A6E3A1" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F38BA8" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F9E2AF" />
    <SolidColorBrush x:Key="InfoBrush" Color="#89DCEB" />

    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="#CBA6F7" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#1E1E2E" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#D5B6F9" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#B48FE6" />

    <!--  Overlays — как в DarkBlue (тёмная база)  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2CFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CCFFFFFF" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44000000" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99000000" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#44CBA6F7" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#33CBA6F7" />

    <!--  Pills — как в DarkBlue  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#5CB85C" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#3F9C3F" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3D8FD1" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#A24CC4" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7A1FA2" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#6A7682" />

    <SolidColorBrush x:Key="OnAccentBrush" Color="#1E1E2E" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF313244" />

    <SolidColorBrush x:Key="NotePanelBrush" Color="#2E3450" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#B4C0F0" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#4A2F3C" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#F0A0B4" />

    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <Color x:Key="SelectedItemStartColor">#57467E</Color>
    <Color x:Key="SelectedItemMidColor">#3F3160</Color>
    <Color x:Key="SelectedItemEndColor">#2A2440</Color>
    <Color x:Key="SidebarSelectStartColor">#57467E</Color>
    <Color x:Key="SidebarSelectEndColor">#3C2E58</Color>
    <Color x:Key="ShimmerColor">#55CBA6F7</Color>

</ResourceDictionary>
