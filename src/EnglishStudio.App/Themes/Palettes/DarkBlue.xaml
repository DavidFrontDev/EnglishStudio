<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DarkBlue palette: точные цвета из MapDownloader2.
        Все ключи именуются по смыслу, не по цвету, чтобы Light.xaml мог переопределить
        те же ключи другими значениями через подмену MergedDictionaries[0].
        Styles ссылаются только на эти ключи через DynamicResource.
    -->

    <!--  ════════ Window background / chrome ════════  -->
    <SolidColorBrush x:Key="WindowBaseBrush" Color="#073a5a" />

    <Color x:Key="AccentHotColor">#3fbfec</Color>
    <Color x:Key="AccentMidColor">#1e96c8</Color>
    <Color x:Key="AccentDeepColor">#0a5c8a</Color>
    <Color x:Key="AccentEdgeColor">#053049</Color>

    <SolidColorBrush x:Key="AccentMidBrush" Color="#1e96c8" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="#3fbfec" />

    <Color x:Key="ChromeStartColor">#212121</Color>
    <Color x:Key="ChromeEndColor">#525252</Color>
    <SolidColorBrush x:Key="ChromeCloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="ChromeClosePressedBrush" Color="#B3000F" />

    <!--  ════════ Text ════════  -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#EAEAEA" />
    <SolidColorBrush x:Key="TitleTextBrush" Color="#EFEFEF" />
    <SolidColorBrush x:Key="StrongTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#C8D2DD" />
    <SolidColorBrush x:Key="CaptionTextBrush" Color="#B5C2D0" />

    <!--  ════════ Semantic ════════  -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#7CFFA0" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF6B6B" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFD54F" />
    <SolidColorBrush x:Key="InfoBrush" Color="#7FD8FF" />

    <!--  ════════ CTA (Accent button) ════════  -->
    <SolidColorBrush x:Key="CtaBackgroundBrush" Color="White" />
    <SolidColorBrush x:Key="CtaForegroundBrush" Color="#0b2a7a" />
    <SolidColorBrush x:Key="CtaHoverBrush" Color="#e8efff" />
    <SolidColorBrush x:Key="CtaPressedBrush" Color="#cfdbff" />

    <!--  ════════ Overlays (glass / borders) ════════  -->
    <SolidColorBrush x:Key="OverlayLight13Brush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight17Brush" Color="#2CFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight20Brush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight33Brush" Color="#55FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight40Brush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight47Brush" Color="#77FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight60Brush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="OverlayLight67Brush" Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="OverlayLight80Brush" Color="#CCFFFFFF" />

    <SolidColorBrush x:Key="OverlayDark13Brush" Color="#22000000" />
    <SolidColorBrush x:Key="OverlayDark20Brush" Color="#33000000" />
    <SolidColorBrush x:Key="OverlayDark27Brush" Color="#44000000" />
    <SolidColorBrush x:Key="OverlayDark33Brush" Color="#55000000" />
    <SolidColorBrush x:Key="OverlayDark40Brush" Color="#66000000" />
    <SolidColorBrush x:Key="OverlayDark60Brush" Color="#99000000" />

    <!--  ════════ Selection ════════  -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#442F80B0" />
    <SolidColorBrush x:Key="SelectionHoverBrush" Color="#332F80B0" />

    <!--  ════════ Pills (CEFR badges)  ═══ Доменно специфично ════  -->
    <SolidColorBrush x:Key="PillA1Brush" Color="#5CB85C" />
    <SolidColorBrush x:Key="PillA2Brush" Color="#3F9C3F" />
    <SolidColorBrush x:Key="PillB1Brush" Color="#3D8FD1" />
    <SolidColorBrush x:Key="PillB2Brush" Color="#2563EB" />
    <SolidColorBrush x:Key="PillC1Brush" Color="#A24CC4" />
    <SolidColorBrush x:Key="PillC2Brush" Color="#7A1FA2" />
    <SolidColorBrush x:Key="PillUnknownBrush" Color="#6A7682" />

    <!--  ════════ On-accent text (тёмный текст на ярком AccentHot-пилле, напр. «BAND») ════════  -->
    <SolidColorBrush x:Key="OnAccentBrush" Color="#073a5a" />

    <!--  ════════ Surfaces (всплывающие списки ComboBox и т.п.) ════════  -->
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF0E2D44" />

    <!--  ════════ Speaking-таймеры: «чип» подготовки (note) и записи (warn).
          Фон держим тёмным во всех темах — поверх идут белые цифры таймера. ════════  -->
    <SolidColorBrush x:Key="NotePanelBrush" Color="#26365E" />
    <SolidColorBrush x:Key="NotePanelTextBrush" Color="#A4C0FF" />
    <SolidColorBrush x:Key="WarnPanelBrush" Color="#5C2A2A" />
    <SolidColorBrush x:Key="WarnPanelTextBrush" Color="#FFB7B7" />

    <!--  ════════ Record button (семантика записи — едина во всех темах) ════════  -->
    <SolidColorBrush x:Key="RecordStartBrush" Color="#3DA66B" />
    <SolidColorBrush x:Key="RecordStopBrush" Color="#C24545" />

    <!--  ════════ Image lightbox (тёмный backdrop во всех темах) ════════  -->
    <SolidColorBrush x:Key="ImageBackdropBrush" Color="#161616" />
    <SolidColorBrush x:Key="ImageBackdropTextBrush" Color="#E0E0E0" />

    <!--  ════════ Selection gradients (заливка выбранной карточки списка и пункта сайдбара).
          В тёмных темах — глубокий акцент (поверх светлый текст); в светлых — бледный (тёмный текст). ════════  -->
    <Color x:Key="SelectedItemStartColor">#125c8e</Color>
    <Color x:Key="SelectedItemMidColor">#0a3f6b</Color>
    <Color x:Key="SelectedItemEndColor">#04263f</Color>
    <Color x:Key="SidebarSelectStartColor">#0A6285</Color>
    <Color x:Key="SidebarSelectEndColor">#03506D</Color>
    <Color x:Key="ShimmerColor">#553FBFEC</Color>

</ResourceDictionary>
